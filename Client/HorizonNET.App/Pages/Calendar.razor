@page "/calendar"
@inject ApiService Api
@inject ProjectState ProjectState
@inject SettingsState Settings
@inject ToastService Toast

<PageTitle>Kalender – HorizonNET</PageTitle>

<h1 class="mb-3">Kalender</h1>

@if (tasks is null)
{
    <p>Wird geladen…</p>
}
else
{
    @* Filter-Legende: Quellen ein-/ausblenden (leer = alles anzeigen) *@
    @if (legend.Count > 0)
    {
        <div class="cal-legend mb-3">
            <span class="cal-legend-label">Anzeigen</span>
            @foreach (var item in legend)
            {
                <button type="button"
                        class="cal-legend-item @(activeFilters.Count > 0 ? (activeFilters.Contains(item.Key) ? "is-active" : "is-inactive") : "")"
                        @onclick="() => ToggleFilterAsync(item.Key)"
                        title="@(activeFilters.Contains(item.Key) ? "Filter entfernen" : "Nur dies anzeigen")">
                    <span class="cal-legend-dot" style="background-color:@item.Color;"></span>
                    @item.Label
                </button>
            }
            @if (activeFilters.Count > 0)
            {
                <button type="button" class="cal-legend-clear" @onclick="ClearFiltersAsync">Alle anzeigen</button>
            }
        </div>
    }

    <div class="d-flex gap-3 align-items-start">
        @* Seitenleiste: ungeplante Tasks (ohne Fälligkeitsdatum) *@
        <div class="calendar-sidebar">
            <div class="fw-semibold mb-2">Ungeplant</div>

            @if (armedTask is not null)
            {
                <div class="alert alert-info py-1 px-2 small mb-2">
                    „@armedTask.Title" – jetzt einen Slot im Kalender anklicken.
                    <button type="button" class="btn-close ms-1" style="font-size:0.6rem;"
                            @onclick="() => armedTask = null" aria-label="Abbrechen"></button>
                </div>
            }

            @{
                // Erledigte/abgebrochene Tasks gehören nicht in die Planungs-Seitenleiste.
                var unscheduled = tasks.Where(t => t.DueDate is null && !t.IsCompleted).ToList();
            }
            @if (unscheduled.Count == 0)
            {
                <p class="text-muted small mb-0">Keine ungeplanten Tasks.</p>
            }
            else
            {
                @foreach (var t in unscheduled)
                {
                    <div class="calendar-unscheduled-item @(armedTask?.Id == t.Id ? "armed" : "")"
                         @onclick="() => ToggleArm(t)">
                        <span class="cal-dot" style="background-color:@(ProjectColor(t.ProjectId) ?? "#6c757d");"></span>
                        <PriorityIndicator Value="@t.Priority" />
                        <span class="text-truncate">@t.Title</span>
                    </div>
                }
            }
        </div>

        @* Kalender *@
        <div class="flex-grow-1">
            <RadzenScheduler @ref="scheduler" TItem="CalendarAppointment" Data="appointments"
                             StartProperty="Start" EndProperty="End" TextProperty="Text"
                             @bind-SelectedIndex="selectedViewIndex"
                             SlotSelect="OnSlotSelect"
                             AppointmentSelect="OnAppointmentSelect"
                             AppointmentMove="OnAppointmentMove"
                             AppointmentRender="OnAppointmentRender"
                             style="height: calc(100vh - 11rem);">
                <ChildContent>
                    <RadzenDayView Text="Tag" StartTime="@(TimeSpan.FromHours(0))" EndTime="@(TimeSpan.FromHours(24))" TimeFormat="HH:mm" />
                    <RadzenWeekView Text="Woche" StartTime="@(TimeSpan.FromHours(0))" EndTime="@(TimeSpan.FromHours(24))" TimeFormat="HH:mm" />
                    <RadzenMonthView Text="Monat" />
                </ChildContent>
                <Template Context="appt">
                    @if (appt.IsGoogle || appt.Task is null)
                    {
                        <span>@appt.Text</span>
                    }
                    else
                    {
                        var t = appt.Task;
                        var prereqs = t.SubTasks;
                        var hasPrereqs = prereqs is { Count: > 0 };
                        var ready = hasPrereqs && prereqs!.All(s => s.IsCompleted);
                        // Inline-Checkboxen nur in der Tagesansicht (Index 0) und nur bei
                        // Terminen mit Uhrzeit (genug Höhe) – sonst kompakt nur mit Status-Icon.
                        var showInline = selectedViewIndex == 0 && hasPrereqs
                                         && t.StartTime is not null && t.EndTime is not null;

                        <div class="cal-appt">
                            <div class="cal-appt-title">
                                @if (hasPrereqs && !t.IsCompleted)
                                {
                                    <span class="cal-ready-badge @(ready ? "cal-ready" : "cal-blocked")">@(ready ? "✓" : "✗")</span>
                                }
                                <span class="@(t.IsCompleted ? "text-decoration-line-through" : "")">@appt.Text</span>
                                <a href="tasks/@t.Id" class="cal-appt-link" title="Zur Detailseite"
                                   @onclick:stopPropagation="true">↗</a>
                            </div>
                            @if (showInline)
                            {
                                <div class="cal-appt-subs">
                                    @foreach (var sub in prereqs!)
                                    {
                                        <label class="cal-appt-sub" @onclick:stopPropagation="true">
                                            <input type="checkbox" checked="@sub.IsCompleted"
                                                   @onchange="() => ToggleSubReadyAsync(t, sub)"
                                                   @onclick:stopPropagation="true" />
                                            <span class="@(sub.IsCompleted ? "text-decoration-line-through" : "")">@sub.Title</span>
                                        </label>
                                    }
                                </div>
                            }
                        </div>
                    }
                </Template>
            </RadzenScheduler>
        </div>
    </div>
}

<TaskEditDialog Task="selectedTask"
                OnSaved="HandleTaskSaved"
                OnDeleted="HandleTaskDeleted"
                OnTaskUpdated="HandleTaskUpdated"
                OnClose="@(() => selectedTask = null)" />

@code {
    private RadzenScheduler<CalendarAppointment>? scheduler;
    private List<TaskResponseDto>? tasks;
    private List<GoogleEventDto> googleEvents = new();
    private List<CalendarAppointment> allAppointments = new();   // ungefiltert
    private List<CalendarAppointment> appointments = new();      // an den Scheduler gebunden (gefiltert)
    private Dictionary<int, string?> projectColors = new();
    private Dictionary<int, string> projectNames = new();
    private TaskResponseDto? selectedTask;   // für den Edit-Dialog
    private TaskResponseDto? armedTask;      // in der Seitenleiste „aufgenommener" Task

    // Aktive Filter-Schlüssel (leer = alles anzeigen): "p:{id}", "none", "google".
    private readonly HashSet<string> activeFilters = new();
    private List<(string Key, string Label, string Color)> legend = new();

    // Aktive Scheduler-Ansicht (0=Tag/1=Woche/2=Monat) – steuert das Termin-Template.
    private int selectedViewIndex;

    protected override async Task OnInitializedAsync()
    {
        await ProjectState.EnsureLoadedAsync();
        await Settings.EnsureLoadedAsync();
        projectColors = (ProjectState.Projects ?? []).ToDictionary(p => p.Id, p => p.Color);
        projectNames = (ProjectState.Projects ?? []).ToDictionary(p => p.Id, p => p.Name);

        // Anfangsansicht aus der gespeicherten Default-Ansicht (0=Tag/1=Woche/2=Monat).
        selectedViewIndex = Settings.CalendarDefaultView;

        tasks = await Api.GetTasksAsync();

        // Google-Termine in einem großzügigen Fenster um heute laden (nur falls verbunden;
        // bei nicht verbunden / Fehler liefert der ApiService eine leere Liste).
        var now = DateTime.Now;
        googleEvents = await Api.GetGoogleEventsAsync(
            now.AddMonths(-1).ToUniversalTime(), now.AddMonths(2).ToUniversalTime());

        BuildAppointments();
    }

    // Tasks mit Fälligkeitsdatum + Google-Termine in Scheduler-Einträge umwandeln,
    // dann Legende neu aufbauen und den aktiven Filter anwenden.
    private void BuildAppointments()
    {
        allAppointments = (tasks ?? [])
            .Where(t => t.DueDate is not null)
            .Select(ToAppointment)
            .Concat(googleEvents.Select(ToAppointment))
            .ToList();

        BuildLegend();
        ApplyFilter();
    }

    // Legende aus den vorhandenen Terminen ableiten: je Projekt mit geplanten Tasks
    // ein Eintrag, dazu „Ohne Projekt" und „Google-Kalender", falls vorhanden.
    private void BuildLegend()
    {
        var items = allAppointments
            .Where(a => a.Task?.ProjectId is not null)
            .Select(a => a.Task!.ProjectId!.Value)
            .Distinct()
            .Select(pid => (
                Key: $"p:{pid}",
                Label: projectNames.GetValueOrDefault(pid, $"Projekt {pid}"),
                Color: (projectColors.TryGetValue(pid, out var c) ? c : null) ?? "#6c757d"))
            .OrderBy(i => i.Label)
            .ToList();

        if (allAppointments.Any(a => a.Task is not null && a.Task.ProjectId is null))
            items.Add(("none", "Ohne Projekt", "#6c757d"));

        if (allAppointments.Any(a => a.IsGoogle))
            items.Add(("google", "Google-Kalender", "#4285F4"));

        legend = items;
    }

    private void ApplyFilter()
    {
        appointments = activeFilters.Count == 0
            ? allAppointments
            : allAppointments.Where(a => activeFilters.Contains(a.FilterKey)).ToList();
    }

    private async Task ToggleFilterAsync(string key)
    {
        if (!activeFilters.Add(key)) activeFilters.Remove(key);
        ApplyFilter();
        if (scheduler is not null) await scheduler.Reload();
    }

    private async Task ClearFiltersAsync()
    {
        activeFilters.Clear();
        ApplyFilter();
        if (scheduler is not null) await scheduler.Reload();
    }

    private CalendarAppointment ToAppointment(GoogleEventDto e) =>
        new() { Start = e.Start, End = e.End, Text = e.Title, IsGoogle = true, FilterKey = "google" };

    private CalendarAppointment ToAppointment(TaskResponseDto t)
    {
        var date = t.DueDate!.Value.Date;
        DateTime start, end;

        if (t.StartTime is not null && t.EndTime is not null)
        {
            start = date + t.StartTime.Value.TimeOfDay;
            end   = date + t.EndTime.Value.TimeOfDay;
            if (end <= start) end = start.AddHours(1);
        }
        else
        {
            start = date;
            end   = date.AddDays(1);
        }

        return new CalendarAppointment
        {
            Start = start,
            End = end,
            Text = t.Title,
            Task = t,
            FilterKey = t.ProjectId is int pid ? $"p:{pid}" : "none"
        };
    }

    private string? ProjectColor(int? projectId)
        => projectId is not null && projectColors.TryGetValue(projectId.Value, out var c) ? c : null;

    // ── Seitenleiste: Task „aufnehmen" und per Slot-Klick platzieren ───────────

    private void ToggleArm(TaskResponseDto t)
        => armedTask = armedTask?.Id == t.Id ? null : t;

    private async Task OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        var task = armedTask;
        if (task is null) return;

        // Zeit-Slot (< 1 Tag) → mit Uhrzeit; Tages-Slot (Monatsansicht) → ganztägig.
        var isTimed = (args.End - args.Start) < TimeSpan.FromDays(1);

        DateTime? due   = args.Start.Date;
        DateTime? start = isTimed ? args.Start : null;
        DateTime? end   = isTimed ? args.End : null;

        var dto = new TaskUpdateDto(
            task.Title, task.Description, due, start, end,
            task.Status, Enum.Parse<Priority>(task.Priority), task.ProjectId);

        var updated = await Api.UpdateTaskAsync(task.Id, dto);
        if (updated is null) return;

        ReplaceTask(updated);
        armedTask = null;
        await RefreshAsync();
    }

    private void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<CalendarAppointment> args)
    {
        // Google-Termine sind read-only – kein Edit-Dialog.
        if (!args.Data.IsGoogle) selectedTask = args.Data.Task;
    }

    // Termin per Drag verschoben → neue Zeit/Datum übernehmen und speichern.
    private async Task OnAppointmentMove(SchedulerAppointmentMoveEventArgs moved)
    {
        if (moved.TimeSpan == TimeSpan.Zero) return;

        var appt = (CalendarAppointment)moved.Appointment.Data;

        // Google-Termine sind read-only und werden nicht verschoben.
        if (appt.IsGoogle || appt.Task is null) return;
        var task = appt.Task;

        var newStart = appt.Start + moved.TimeSpan;
        var newEnd   = appt.End + moved.TimeSpan;

        // Ganztägig (kein Start/Ende) bleibt ganztägig – nur das Datum ändert sich.
        var isTimed = task.StartTime is not null && task.EndTime is not null;

        DateTime? due   = newStart.Date;
        DateTime? start = isTimed ? newStart : null;
        DateTime? end   = isTimed ? newEnd : null;

        var dto = new TaskUpdateDto(
            task.Title, task.Description, due, start, end,
            task.Status, Enum.Parse<Priority>(task.Priority), task.ProjectId);

        var updated = await Api.UpdateTaskAsync(task.Id, dto);
        if (updated is null) return;

        ReplaceTask(updated);
        await RefreshAsync();
    }

    // Look wie die Projektkarten in der Übersicht: abgeschwächter Farbton (~10 %),
    // farbiger Rand + dezenter linker Akzent, dunkler Text. Google = Google-Blau.
    private void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<CalendarAppointment> args)
    {
        var color = args.Data.IsGoogle ? "#4285F4" : (ProjectColor(args.Data.Task?.ProjectId) ?? "#6c757d");
        args.Attributes["style"] =
            $"background-color: {color}1A; border: 1px solid {color}; border-left: 3px solid {color}; color: #212529;";
    }

    // Sub-Task (Voraussetzung) direkt im Tages-Termin abhaken. Aktualisiert den
    // lokalen Stand und baut die Termine neu, damit das Bereit-Icon nachzieht.
    private async Task ToggleSubReadyAsync(TaskResponseDto parent, TaskResponseDto sub)
    {
        if (parent.SubTasks is null) return;

        var newStatus = sub.IsCompleted ? WorkStatus.Planned : WorkStatus.Done;
        var dto = new TaskUpdateDto(
            sub.Title, sub.Description, sub.DueDate, sub.StartTime, sub.EndTime,
            newStatus, Enum.Parse<Priority>(sub.Priority), sub.ProjectId);

        var updated = await Api.UpdateTaskAsync(sub.Id, dto);
        if (updated is null) return;

        var idx = parent.SubTasks.FindIndex(s => s.Id == sub.Id);
        if (idx >= 0) parent.SubTasks[idx] = updated;

        await RefreshAsync();
    }

    // ── Dialog-Callbacks ───────────────────────────────────────────────────────

    private async Task HandleTaskSaved(TaskResponseDto updated)
    {
        ReplaceTask(updated);
        selectedTask = null;
        await RefreshAsync();
    }

    private async Task HandleTaskUpdated(TaskResponseDto updated)
    {
        ReplaceTask(updated);
        await RefreshAsync();
    }

    private async Task HandleTaskDeleted(int id)
    {
        var title = tasks?.FirstOrDefault(t => t.Id == id)?.Title;
        tasks?.RemoveAll(t => t.Id == id);
        selectedTask = null;
        await RefreshAsync();

        Toast.ShowUndo(string.IsNullOrWhiteSpace(title) ? "Task gelöscht" : $"{title} gelöscht", async () =>
        {
            if (!await Api.RestoreTaskAsync(id)) return;
            tasks = await Api.GetTasksAsync();
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        });
    }

    private void ReplaceTask(TaskResponseDto updated)
    {
        if (tasks is null) return;
        var idx = tasks.FindIndex(t => t.Id == updated.Id);
        if (idx >= 0) tasks[idx] = updated;
    }

    private async Task RefreshAsync()
    {
        BuildAppointments();
        if (scheduler is not null) await scheduler.Reload();
    }

    private class CalendarAppointment
    {
        public DateTime Start { get; set; }
        public DateTime End { get; set; }
        public string Text { get; set; } = "";

        // Bei Task-Terminen gesetzt; bei read-only Google-Terminen null.
        public TaskResponseDto? Task { get; set; }

        public bool IsGoogle { get; set; }

        // Schlüssel für die Filter-Legende: "p:{projektId}", "none" oder "google".
        public string FilterKey { get; set; } = "none";
    }
}
