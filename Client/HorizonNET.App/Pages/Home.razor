@page "/"
@inject ApiService Api
@inject ProjectState ProjectState
@inject WorkspaceState WorkspaceState
@inject IStringLocalizer<Home> L
@inject IStringLocalizer<Enums> EnumL

<PageTitle>@L["PageTitle"]</PageTitle>

<h1>@L["Heading"]</h1>

@if (projects is null)
{
    <p>@L["Loading"]</p>
}
else
{
    @* ── Arbeitsbereiche ───────────────────────────────────────────────── *@
    var workspacesExpanded = expandedSections["Workspaces"];
    <div class="card mb-3 overflow-hidden">
        <button class="btn btn-light w-100 d-flex justify-content-between align-items-center border-0 rounded-0 @(workspacesExpanded ? "border-bottom" : "")"
                @onclick='() => ToggleSection("Workspaces")'>
            <span class="fw-semibold">
                <span class="badge bg-secondary me-2">@(workspaces?.Count ?? 0)</span>
                @L["Workspaces_Title"]
            </span>
            <span>@(workspacesExpanded ? "▲" : "▼")</span>
        </button>

        @if (workspacesExpanded)
        {
            <div class="card-body">
                @if (workspaces is not null && workspaces.Any())
                {
                    <ul class="list-group mb-3">
                        @foreach (var ws in workspaces)
                        {
                            <li class="list-group-item">
                                @if (editingWorkspaceId == ws.Id)
                                {
                                    <EditForm Model="editWorkspace" OnValidSubmit="SaveWorkspaceEditAsync" class="row g-2">
                                        <DataAnnotationsValidator />
                                        <div class="col-12 col-md-4">
                                            <InputText class="form-control form-control-sm" @bind-Value="editWorkspace.Name" placeholder="@L["Field_Name"]" />
                                            <ValidationMessage For="() => editWorkspace.Name" />
                                        </div>
                                        <div class="col-12 col-md-5">
                                            <InputText class="form-control form-control-sm" @bind-Value="editWorkspace.Description" placeholder="@L["Field_Description"]" />
                                        </div>
                                        <div class="col-auto d-flex align-items-center gap-2">
                                            <input type="color" class="form-control form-control-color form-control-sm"
                                                   value="@(editWorkspace.Color ?? "#6c757d")"
                                                   @oninput="e => editWorkspace.Color = e.Value?.ToString()" />
                                            <button type="submit" class="btn btn-sm btn-primary" disabled="@isSaving">@L["Button_Save"]</button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelEditWorkspace">@L["Button_Cancel"]</button>
                                        </div>
                                    </EditForm>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="d-flex align-items-center gap-2">
                                            <span class="nav-project-dot" style="display:inline-block;width:0.7rem;height:0.7rem;border-radius:2px;background-color:@(ws.Color ?? "#6c757d");"></span>
                                            <a href="workspaces/@ws.Id" class="fw-semibold text-decoration-none">@ws.Name</a>
                                            <span class="badge bg-light text-dark">@ProjectCountLabel(ws.ProjectCount)</span>
                                            <span class="badge bg-light text-dark">@OpenTasksLabel(OpenTasksInWorkspace(ws.Id))</span>
                                            @if (ws.Description is not null)
                                            {
                                                <span class="text-muted small">@ws.Description</span>
                                            }
                                        </span>
                                        <span class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary btn-icon" @onclick="() => StartEditWorkspace(ws)" title="@L["Button_Edit_Title"]">✎</button>
                                            <button class="btn btn-sm btn-outline-danger btn-icon" @onclick="() => DeleteWorkspaceAsync(ws)" title="@L["Button_Delete_Title"]">🗑</button>
                                        </span>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small">@L["Workspaces_Empty"]</p>
                }

                @if (showWorkspaceForm)
                {
                    <EditForm Model="newWorkspace" OnValidSubmit="CreateWorkspaceAsync" class="row g-2 align-items-end">
                        <DataAnnotationsValidator />
                        <div class="col-12 col-md-4">
                            <label class="form-label small mb-1">@L["Field_Name"]</label>
                            <InputText class="form-control form-control-sm" @bind-Value="newWorkspace.Name" />
                            <ValidationMessage For="() => newWorkspace.Name" />
                        </div>
                        <div class="col-12 col-md-5">
                            <label class="form-label small mb-1">@L["Field_Description"]</label>
                            <InputText class="form-control form-control-sm" @bind-Value="newWorkspace.Description" />
                        </div>
                        <div class="col-auto d-flex align-items-center gap-2">
                            <input type="color" class="form-control form-control-color form-control-sm"
                                   value="@(newWorkspace.Color ?? "#6c757d")"
                                   @oninput="e => newWorkspace.Color = e.Value?.ToString()" />
                            <button type="submit" class="btn btn-sm btn-primary" disabled="@isSaving">@L["Button_Save"]</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleWorkspaceForm">@L["Button_Cancel"]</button>
                        </div>
                        @if (workspaceErrorMessage is not null)
                        {
                            <div class="col-12"><div class="alert alert-danger py-1 mb-0">@workspaceErrorMessage</div></div>
                        }
                    </EditForm>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="ToggleWorkspaceForm">@L["Workspaces_New"]</button>
                }
            </div>
        }
    </div>

    @foreach (var section in Sections)
    {
        var sectionProjects = projects.Where(p => p.Status == section.StatusLabel).ToList();
        var isExpanded = expandedSections[section.StatusLabel];

        <div class="card mb-3 overflow-hidden">
            <button class="btn btn-light w-100 d-flex justify-content-between align-items-center border-0 rounded-0 @(isExpanded ? "border-bottom" : "")"
                    @onclick="() => ToggleSection(section.StatusLabel)">
                <span class="fw-semibold">
                    <span class="badge @section.BadgeClass me-2">@sectionProjects.Count</span>
                    @L[section.TitleKey]
                </span>
                <span>@(isExpanded ? "▲" : "▼")</span>
            </button>

            @if (isExpanded)
            {
                <div class="card-body">
                @if (!sectionProjects.Any())
                {
                    <p class="text-muted small mb-0">@L["Section_Empty"]</p>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var project in sectionProjects)
                        {
                            <div class="col">
                                <div class="card h-100"
                                     style="@(project.Color is not null ? $"background-color: {project.Color}1A; border-color: {project.Color};" : "")">
                                    @if (editingProjectId == project.Id)
                                    {
                                        <div class="card-body">
                                            <EditForm Model="editProject" OnValidSubmit="SaveEditAsync" class="row g-2">
                                                <DataAnnotationsValidator />
                                                <div class="col-12">
                                                    <InputText class="form-control" @bind-Value="editProject.Name" placeholder="@L["Field_Name"]" />
                                                    <ValidationMessage For="() => editProject.Name" />
                                                </div>
                                                <div class="col-12">
                                                    <InputTextArea class="form-control" rows="2" @bind-Value="editProject.Description" placeholder="@L["Field_Description"]" />
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small">@L["Field_Status"]</label>
                                                    <InputSelect class="form-select form-select-sm" @bind-Value="editProject.Status">
                                                        @foreach (var s in Enum.GetValues<ProjectStatus>())
                                                        {
                                                            <option value="@s">@EnumL[$"ProjectStatus_{s}"]</option>
                                                        }
                                                    </InputSelect>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small">@L["Field_Priority"]</label>
                                                    <InputSelect class="form-select form-select-sm" @bind-Value="editProject.Priority">
                                                        @foreach (var p in Enum.GetValues<Priority>())
                                                        {
                                                            <option value="@p">@PriorityDisplay.Symbol(p) @EnumL[$"Priority_{p}"]</option>
                                                        }
                                                    </InputSelect>
                                                </div>
                                                <div class="col-12 d-flex align-items-center gap-2">
                                                    <label class="form-label small mb-0">@L["Field_Color"]</label>
                                                    <input type="color" class="form-control form-control-color"
                                                           value="@(editProject.Color ?? "#6c757d")"
                                                           @oninput="e => editProject.Color = e.Value?.ToString()" />
                                                    @if (editProject.Color is not null)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                                                @onclick="() => editProject.Color = null">@L["Button_ColorReset"]</button>
                                                    }
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label small">@L["Field_Workspace"]</label>
                                                    <InputSelect class="form-select form-select-sm" @bind-Value="editProject.WorkspaceId">
                                                        <option value="">@L["Workspace_None"]</option>
                                                        @if (workspaces is not null)
                                                        {
                                                            @foreach (var ws in workspaces)
                                                            {
                                                                <option value="@ws.Id">@ws.Name</option>
                                                            }
                                                        }
                                                    </InputSelect>
                                                </div>
                                                @if (editErrorMessage is not null)
                                                {
                                                    <div class="col-12"><div class="alert alert-danger py-1">@editErrorMessage</div></div>
                                                }
                                                <div class="col-12 d-flex gap-2">
                                                    <button type="submit" class="btn btn-sm btn-primary" disabled="@isSaving">
                                                        @(isSaving ? L["Button_Saving"] : L["Button_Save"])
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">@L["Button_Cancel"]</button>
                                                </div>
                                            </EditForm>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="card-header d-flex justify-content-between align-items-center" style="background-color: transparent; border-color: rgba(0,0,0,0.1);">
                                            <div class="d-flex align-items-center gap-2">
                                                <a href="/projects/@project.Id" class="text-decoration-none fw-bold text-dark">
                                                    @project.Name
                                                </a>
                                                <PriorityIndicator Value="@project.Priority" />
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-outline-primary btn-icon" @onclick="() => StartEdit(project)" title="@L["Button_Edit_Title"]">✎</button>
                                                <button class="btn btn-sm btn-outline-danger btn-icon" @onclick="() => DeleteProjectAsync(project)" title="@L["Button_Delete_Title"]">🗑</button>
                                            </div>
                                        </div>

                                        <div class="card-body">
                                            @if (project.Description is not null)
                                            {
                                                <p class="card-text text-muted small">@project.Description</p>
                                            }
                                        </div>

                                        <div class="card-footer text-muted small">
                                            @{
                                                var openTasks = project.TaskCount - project.DoneTaskCount;
                                                var pct = project.TaskCount > 0
                                                    ? (int)Math.Round(project.DoneTaskCount * 100.0 / project.TaskCount)
                                                    : 0;
                                            }
                                            @if (project.TaskCount > 0)
                                            {
                                                <div class="progress mb-1" style="height: 5px;">
                                                    <div class="progress-bar" role="progressbar"
                                                         style="width: @pct%;"
                                                         aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <div class="d-flex justify-content-between">
                                                    <span>@string.Format(L["Card_Progress"], pct, openTasks)</span>
                                                    <span>@string.Format(L["Card_CreatedAt"], project.CreatedAt.ToString("dd.MM.yyyy"))</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex justify-content-between">
                                                    <span>@L["Card_NoTasks"]</span>
                                                    <span>@string.Format(L["Card_CreatedAt"], project.CreatedAt.ToString("dd.MM.yyyy"))</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                </div>
            }
        </div>
    }
}

<!-- Formular zum Anlegen eines neuen Projekts -->
<button class="btn btn-outline-primary mb-3" @onclick="ToggleForm">
    @(showForm ? L["NewProject_Cancel"] : L["NewProject_Button"])
</button>

@if (showForm)
{
    <EditForm Model="newProject" OnValidSubmit="CreateProjectAsync" class="card p-3 mb-4">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">@L["Field_Name"]</label>
            <InputText class="form-control" @bind-Value="newProject.Name" />
            <ValidationMessage For="() => newProject.Name" />
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Field_Description"]</label>
            <InputTextArea class="form-control" rows="2" @bind-Value="newProject.Description" />
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Field_Status"]</label>
            <InputSelect class="form-select" @bind-Value="newProject.Status">
                @foreach (var status in Enum.GetValues<ProjectStatus>())
                {
                    <option value="@status">@EnumL[$"ProjectStatus_{status}"]</option>
                }
            </InputSelect>
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Field_Priority"]</label>
            <InputSelect class="form-select" @bind-Value="newProject.Priority">
                @foreach (var priority in Enum.GetValues<Priority>())
                {
                    <option value="@priority">@PriorityDisplay.Symbol(priority) @EnumL[$"Priority_{priority}"]</option>
                }
            </InputSelect>
        </div>
        <div class="mb-3 d-flex align-items-center gap-2">
            <label class="form-label mb-0">@L["Field_Color"]</label>
            <input type="color" class="form-control form-control-color"
                   value="@(newProject.Color ?? "#6c757d")"
                   @oninput="e => newProject.Color = e.Value?.ToString()" />
            @if (newProject.Color is not null)
            {
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        @onclick="() => newProject.Color = null">@L["Button_ColorReset"]</button>
            }
        </div>
        <div class="mb-3">
            <label class="form-label">@L["Field_Workspace"]</label>
            <InputSelect class="form-select" @bind-Value="newProject.WorkspaceId">
                <option value="">@L["Workspace_None"]</option>
                @if (workspaces is not null)
                {
                    @foreach (var ws in workspaces)
                    {
                        <option value="@ws.Id">@ws.Name</option>
                    }
                }
            </InputSelect>
        </div>
        @if (errorMessage is not null)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        <button type="submit" class="btn btn-primary" disabled="@isSaving">
            @(isSaving ? L["NewProject_Saving"] : L["NewProject_Save"])
        </button>
    </EditForm>
}

@code {
    // Projekte werden im geteilten ProjectState gehalten, damit die
    // Navigationsleiste bei Änderungen mit aktualisiert wird.
    private List<ProjectResponseDto>? projects
    {
        get => ProjectState.Projects;
        set => ProjectState.Set(value);
    }

    // Arbeitsbereiche werden ebenfalls im geteilten State gehalten.
    private List<WorkspaceResponseDto>? workspaces
    {
        get => WorkspaceState.Workspaces;
        set => WorkspaceState.Set(value);
    }

    // Sektionen
    private record SectionDef(string StatusLabel, string TitleKey, string BadgeClass);
    private static readonly SectionDef[] Sections =
    [
        new("Active",   "Section_Active",   "bg-success"),
        new("Paused",   "Section_Paused",   "bg-warning text-dark"),
        new("Archived", "Section_Archived", "bg-secondary"),
    ];
    private Dictionary<string, bool> expandedSections = new()
    {
        ["Workspaces"] = true,
        ["Active"]     = true,
        ["Paused"]     = false,
        ["Archived"]   = false,
    };
    private void ToggleSection(string key) => expandedSections[key] = !expandedSections[key];

    // Erstellen
    private ProjectCreateFormModel newProject = new();
    private bool showForm;
    private bool isSaving;
    private string? errorMessage;

    // Bearbeiten
    private int? editingProjectId;
    private ProjectEditFormModel editProject = new();
    private string? editErrorMessage;

    // Arbeitsbereiche
    private bool showWorkspaceForm;
    private WorkspaceFormModel newWorkspace = new();
    private int? editingWorkspaceId;
    private WorkspaceFormModel editWorkspace = new();
    private string? workspaceErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await ProjectState.EnsureLoadedAsync();
        await WorkspaceState.EnsureLoadedAsync();
    }

    // ── Bearbeiten ───────────────────────────────────────────────────────────

    private void StartEdit(ProjectResponseDto project)
    {
        editingProjectId = project.Id;
        editErrorMessage = null;
        editProject = new ProjectEditFormModel
        {
            Name        = project.Name,
            Description = project.Description,
            Status      = Enum.Parse<ProjectStatus>(project.Status),
            Priority    = Enum.Parse<Priority>(project.Priority),
            Color       = project.Color,
            WorkspaceId = project.WorkspaceId
        };
    }

    private void CancelEdit()
    {
        editingProjectId = null;
        editErrorMessage = null;
    }

    private async Task SaveEditAsync()
    {
        if (editingProjectId is null || projects is null) return;

        isSaving         = true;
        editErrorMessage = null;

        var dto = new ProjectUpdateDto(
            editProject.Name,
            string.IsNullOrWhiteSpace(editProject.Description) ? null : editProject.Description,
            editProject.Status,
            editProject.Priority,
            editProject.Color,
            editProject.WorkspaceId);

        var previousWorkspaceId = projects.FirstOrDefault(p => p.Id == editingProjectId)?.WorkspaceId;

        var updated = await Api.UpdateProjectAsync(editingProjectId.Value, dto);
        if (updated is not null)
        {
            var idx = projects.FindIndex(p => p.Id == editingProjectId);
            if (idx >= 0) projects[idx] = updated;
            ProjectState.NotifyChanged();
            if (updated.WorkspaceId != previousWorkspaceId)
                await WorkspaceState.RefreshAsync();
            editingProjectId = null;
        }
        else
        {
            editErrorMessage = L["NewProject_Error"];
        }

        isSaving = false;
    }

    // ── Löschen ──────────────────────────────────────────────────────────────

    private async Task DeleteProjectAsync(ProjectResponseDto project)
    {
        var success = await Api.DeleteProjectAsync(project.Id);
        if (success)
        {
            projects?.Remove(project);
            ProjectState.NotifyChanged();
            if (project.WorkspaceId is not null)
                await WorkspaceState.RefreshAsync();
        }
    }

    // ── Erstellen ────────────────────────────────────────────────────────────

    private void ToggleForm()
    {
        showForm     = !showForm;
        errorMessage = null;
        newProject   = new();
    }

    private async Task CreateProjectAsync()
    {
        isSaving     = true;
        errorMessage = null;

        var dto = new ProjectCreateDto(
            newProject.Name,
            string.IsNullOrWhiteSpace(newProject.Description) ? null : newProject.Description,
            newProject.Status,
            newProject.Priority,
            newProject.Color,
            newProject.WorkspaceId);

        var created = await Api.CreateProjectAsync(dto);
        if (created is not null)
        {
            projects ??= [];
            projects.Add(created);
            ProjectState.NotifyChanged();
            if (created.WorkspaceId is not null)
                await WorkspaceState.RefreshAsync();
            showForm   = false;
            newProject = new();
        }
        else
        {
            errorMessage = L["NewProject_Error"];
        }

        isSaving = false;
    }

    // ── Arbeitsbereiche ────────────────────────────────────────────────────────

    // Summe der offenen Tasks aller Projekte eines Arbeitsbereichs
    private int OpenTasksInWorkspace(int workspaceId) =>
        projects?.Where(p => p.WorkspaceId == workspaceId)
                 .Sum(p => p.TaskCount - p.DoneTaskCount) ?? 0;

    // Beschriftungen mit korrekter Singular-/Pluralform
    private string ProjectCountLabel(int count) =>
        string.Format(L[count == 1 ? "Workspaces_ProjectCount_One" : "Workspaces_ProjectCount"], count);

    private string OpenTasksLabel(int count) =>
        string.Format(L[count == 1 ? "Workspaces_OpenTasks_One" : "Workspaces_OpenTasks"], count);

    private void ToggleWorkspaceForm()
    {
        showWorkspaceForm     = !showWorkspaceForm;
        workspaceErrorMessage = null;
        newWorkspace          = new();
    }

    private async Task CreateWorkspaceAsync()
    {
        isSaving              = true;
        workspaceErrorMessage = null;

        var dto = new WorkspaceCreateDto(
            newWorkspace.Name,
            string.IsNullOrWhiteSpace(newWorkspace.Description) ? null : newWorkspace.Description,
            newWorkspace.Color);

        var created = await Api.CreateWorkspaceAsync(dto);
        if (created is not null)
        {
            workspaces ??= [];
            workspaces.Add(created);
            WorkspaceState.NotifyChanged();
            showWorkspaceForm = false;
            newWorkspace      = new();
        }
        else
        {
            workspaceErrorMessage = L["Workspaces_Error"];
        }

        isSaving = false;
    }

    private void StartEditWorkspace(WorkspaceResponseDto ws)
    {
        editingWorkspaceId    = ws.Id;
        workspaceErrorMessage = null;
        editWorkspace = new WorkspaceFormModel
        {
            Name        = ws.Name,
            Description = ws.Description,
            Color       = ws.Color
        };
    }

    private void CancelEditWorkspace()
    {
        editingWorkspaceId    = null;
        workspaceErrorMessage = null;
    }

    private async Task SaveWorkspaceEditAsync()
    {
        if (editingWorkspaceId is null || workspaces is null) return;

        isSaving = true;

        var dto = new WorkspaceUpdateDto(
            editWorkspace.Name,
            string.IsNullOrWhiteSpace(editWorkspace.Description) ? null : editWorkspace.Description,
            editWorkspace.Color);

        var updated = await Api.UpdateWorkspaceAsync(editingWorkspaceId.Value, dto);
        if (updated is not null)
        {
            var idx = workspaces.FindIndex(w => w.Id == editingWorkspaceId);
            if (idx >= 0) workspaces[idx] = updated;
            WorkspaceState.NotifyChanged();
            editingWorkspaceId = null;
        }

        isSaving = false;
    }

    private async Task DeleteWorkspaceAsync(WorkspaceResponseDto ws)
    {
        var success = await Api.DeleteWorkspaceAsync(ws.Id);
        if (!success) return;

        workspaces?.Remove(ws);
        WorkspaceState.NotifyChanged();

        // Projekte dieses Bereichs verlieren serverseitig ihre Zuordnung
        // (ON DELETE SET NULL) – lokalen Projekt-State entsprechend angleichen.
        if (projects is not null)
        {
            for (var i = 0; i < projects.Count; i++)
            {
                if (projects[i].WorkspaceId == ws.Id)
                    projects[i] = projects[i] with { WorkspaceId = null };
            }
            ProjectState.NotifyChanged();
        }
    }

    // ── Formularmodelle ──────────────────────────────────────────────────────

    private class ProjectCreateFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name ist erforderlich.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public ProjectStatus Status { get; set; } = ProjectStatus.Active;
        public Priority Priority { get; set; } = Priority.Medium;
        public string? Color { get; set; }
        public int? WorkspaceId { get; set; }
    }

    private class ProjectEditFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name ist erforderlich.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public ProjectStatus Status { get; set; } = ProjectStatus.Active;
        public Priority Priority { get; set; } = Priority.Medium;
        public string? Color { get; set; }
        public int? WorkspaceId { get; set; }
    }

    private class WorkspaceFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name ist erforderlich.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Color { get; set; }
    }
}
