@page "/projects/{Id:int}"
@inject ApiService Api
@inject ProjectState ProjectState
@inject IStringLocalizer<ProjectDetail> L
@inject IStringLocalizer<Enums> EnumL
@inject ToastService Toast
@inject SoundService Sound

<PageTitle>Projekt – HorizonNET</PageTitle>

@if (project is null)
{
    <p>@L["Loading"]</p>
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-2">
        <h1>@project.Name</h1>
        <button class="btn btn-sm btn-outline-primary btn-icon flex-shrink-0"
                @onclick="() => showProjectDialog = true" title="@L["Button_Edit_Title"]">✎</button>
    </div>

    <div class="mb-3">
        @if (project.Description is not null)
        {
            <p class="text-muted">@project.Description</p>
        }
        <span class="badge bg-secondary me-1">@EnumL[$"ProjectStatus_{project.Status}"]</span>
        <PriorityIndicator Value="@project.Priority" />
    </div>

    <h2>Tasks</h2>

    @if (tasks is null)
    {
        <p>@L["Loading"]</p>
    }
    else if (!tasks.Any())
    {
        <p>@L["NoTasks"]</p>
    }
    else
    {
        @* Sortiert wird beim Rendern, nicht in der Liste selbst – dadurch stimmt die
           Reihenfolge sofort nach jeder Statusänderung, ohne Neuladen. *@
        <ul class="list-group mb-4">
            @foreach (var task in tasks.SortedByDefault())
            {
                @* @key ist hier zwingend: eine Statusänderung sortiert die Liste um. Ohne
                   Schlüssel verwendet Blazor die <li> positionsweise wieder – das Status-
                   Dropdown des nachrückenden Tasks behielte dann die vom Nutzer gewählte
                   Auswahl (z. B. "Fertig"), weil sich sein value-Attribut nicht ändert. *@
                <!-- Parent-Task -->
                <li @key="task.Id" class="list-group-item @(task.IsCompleted ? "task-completed" : "")">
                    @TaskRow(task, isSubTask: false)
                </li>

                <!-- Sub-Tasks eingerückt darunter -->
                @if (task.SubTasks is { Count: > 0 })
                {
                    @foreach (var sub in task.SubTasks.SortedByDefault())
                    {
                        <li @key="sub.Id" class="list-group-item ps-5 @(sub.IsCompleted ? "task-completed" : "") subtask-item">
                            @TaskRow(sub, isSubTask: true)
                        </li>
                    }
                }

                <!-- Sub-Task-Erstellformular -->
                @if (addingSubTaskForId == task.Id)
                {
                    <li class="list-group-item ps-5 subtask-item">
                        <EditForm Model="newSubTask" OnValidSubmit="() => CreateSubTaskAsync(task.Id)" class="row g-2">
                            <DataAnnotationsValidator />
                            <div class="col-12">
                                <InputText class="form-control form-control-sm" @bind-Value="newSubTask.Title" placeholder="@L["SubTask_Placeholder"]" />
                                <ValidationMessage For="() => newSubTask.Title" />
                            </div>
                            <div class="col-md-6">
                                <InputDate class="form-control form-control-sm" @bind-Value="newSubTask.DueDate" />
                            </div>
                            <div class="col-md-6">
                                <InputSelect class="form-select form-select-sm" @bind-Value="newSubTask.Priority">
                                    @foreach (var p in Enum.GetValues<Priority>())
                                    {
                                        <option value="@p">@PriorityDisplay.Symbol(p) @EnumL[$"Priority_{p}"]</option>
                                    }
                                </InputSelect>
                            </div>
                            @if (subTaskErrorMessage is not null)
                            {
                                <div class="col-12"><div class="alert alert-danger py-1">@subTaskErrorMessage</div></div>
                            }
                            <div class="col-12 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary" disabled="@isSaving">@L["Task_EditSave"]</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelSubTask">@L["Task_EditCancel"]</button>
                            </div>
                        </EditForm>
                    </li>
                }
            }
        </ul>
    }

    <!-- Formular zum Anlegen eines neuen Tasks -->
    <button class="btn btn-outline-primary mb-3" @onclick="ToggleForm">
        @(showForm ? L["NewTask_Cancel"] : L["NewTask_Button"])
    </button>

    @if (showForm)
    {
        <EditForm Model="newTask" OnValidSubmit="CreateTaskAsync" class="card p-3 mb-4">
            <DataAnnotationsValidator />

            @* Vorlage belegt Titel, Beschreibung und Priorität vor; das Projekt steht
               auf dieser Seite ohnehin fest und wird aus der Vorlage nicht übernommen. *@
            <div class="mb-3">
                <label class="form-label">@L["Field_Template"]</label>
                <TaskTemplatePicker OnSelected="ApplyTemplate" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Field_Title"]</label>
                <InputText class="form-control" @bind-Value="newTask.Title" />
                <ValidationMessage For="() => newTask.Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Field_Description"]</label>
                <InputTextArea class="form-control" rows="2" @bind-Value="newTask.Description" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Field_DueDate"]</label>
                <InputDate class="form-control" @bind-Value="newTask.DueDate" />
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label">@L["Field_StartTime"]</label>
                    <InputDate class="form-control" Type="InputDateType.Time" @bind-Value="newTask.StartTime" />
                </div>
                <div class="col">
                    <label class="form-label">@L["Field_EndTime"]</label>
                    <InputDate class="form-control" Type="InputDateType.Time" @bind-Value="newTask.EndTime" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Field_Priority"]</label>
                <InputSelect class="form-select" @bind-Value="newTask.Priority">
                    @foreach (var priority in Enum.GetValues<Priority>())
                    {
                        <option value="@priority">@PriorityDisplay.Symbol(priority) @EnumL[$"Priority_{priority}"]</option>
                    }
                </InputSelect>
            </div>
            @if (errorMessage is not null)
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @(isSaving ? L["NewTask_Saving"] : L["NewTask_Save"])
            </button>
        </EditForm>
    }

    @* ── Notizen zum Projekt (Muster wie auf der Task-Detailseite) ───────────── *@
    <hr class="my-4" />

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">Notizen</h2>
        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="CreateNoteAsync">
            + Neue Notiz
        </button>
    </div>

    @if (notes is null)
    {
        <p class="text-muted small mb-0">@L["Loading"]</p>
    }
    else
    {
        @if (notes.Count > 0)
        {
            <div class="border rounded mb-3">
                <NoteList Notes="notes" SelectedId="selectedNote?.Id" OnSelect="SelectNoteAsync" />
            </div>
        }
        else if (selectedNote is null)
        {
            <p class="text-muted small">Noch keine Notizen zu diesem Projekt.</p>
        }

        @if (selectedNote is not null)
        {
            <div class="border rounded p-2 mb-4">
                <NoteEditor @ref="noteEditor" Note="selectedNote"
                            OnSaved="HandleNoteSaved" OnDeleted="HandleNoteDeleted" />
            </div>
        }
    }
}

<TaskEditDialog Task="selectedTask"
                OnSaved="HandleTaskSaved"
                OnDeleted="HandleTaskDeleted"
                OnTaskUpdated="HandleTaskUpdated"
                OnClose="@(() => selectedTask = null)" />

<ProjectEditDialog Visible="showProjectDialog"
                   Project="project"
                   OnSaved="HandleProjectSavedAsync"
                   OnClose="@(() => showProjectDialog = false)" />

@code {
    [Parameter] public int Id { get; set; }

    private ProjectResponseDto? project;
    private List<TaskResponseDto>? tasks;
    private int? loadedId;

    // Notizen zum Projekt (Muster wie TaskDetail)
    private List<NoteResponseDto>? notes;
    private NoteResponseDto? selectedNote;
    private NoteEditor? noteEditor;

    // Projekt bearbeiten (geteilter Dialog)
    private bool showProjectDialog;

    // Neuer Task
    private TaskCreateFormModel newTask = new();
    private bool showForm;
    private bool isSaving;
    private string? errorMessage;

    // Bearbeiten-Dialog (geteilte Komponente)
    private TaskResponseDto? selectedTask;

    // Neuer Sub-Task
    private int? addingSubTaskForId;
    private TaskCreateFormModel newSubTask = new();
    private string? subTaskErrorMessage;

    // OnParametersSetAsync statt OnInitializedAsync: lädt neu beim Wechsel
    // zwischen zwei Projekten (gleiche Komponenteninstanz, nur Id ändert sich).
    protected override async Task OnParametersSetAsync()
    {
        if (loadedId == Id) return;

        // Der NoteEditor wird beim Projektwechsel nicht disposed (nur Note = null),
        // deshalb greift der Dispose-Flush nicht – offene Änderungen hier sichern.
        if (noteEditor is not null) await noteEditor.FlushAsync();

        loadedId = Id;

        // Beim Projektwechsel Daten und transienten UI-Zustand zurücksetzen.
        project            = null;
        tasks              = null;
        notes              = null;
        selectedNote       = null;
        selectedTask       = null;
        showForm           = false;
        addingSubTaskForId = null;

        project = await Api.GetProjectAsync(Id);
        tasks   = await Api.GetTasksByProjectAsync(Id);
        notes   = await Api.GetNotesByProjectAsync(Id) ?? new();
    }

    // ── Render-Helfer ────────────────────────────────────────────────────────

    private RenderFragment TaskRow(TaskResponseDto task, bool isSubTask) => __builder =>
    {
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                @* Schnell-Abschluss: Haken setzt auf "Fertig", Abwählen zurück auf "Geplant". *@
                <input type="checkbox" class="form-check-input task-done-check flex-shrink-0"
                       checked="@task.IsCompleted"
                       @onchange="async e => await ToggleDoneAsync(task, (bool)e.Value!)"
                       title="@(task.IsCompleted ? L["Task_Undone_Title"] : L["Task_Done_Title"])" />

                <select class="form-select form-select-sm w-auto"
                        value="@task.Status"
                        @onchange="async e => await ChangeStatusAsync(task, Enum.Parse<WorkStatus>(e.Value!.ToString()!))">
                    @foreach (var s in Enum.GetValues<WorkStatus>())
                    {
                        <option value="@s">@EnumL[$"WorkStatus_{s}"]</option>
                    }
                </select>
                <div>
                    <a href="@($"tasks/{task.Id}")" class="task-title-link" title="@L["Button_Edit_Title"]">
                        <strong class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                            @task.Title
                        </strong>
                    </a>
                    @if (task.Description is not null)
                    {
                        <span class="text-muted ms-2">@task.Description</span>
                    }
                    @if (task.DueDate is not null)
                    {
                        <div class="small text-muted">
                            @string.Format(L["Task_DueDate"], task.DueDate.Value.ToString("dd.MM.yyyy"))
                            @if (task.StartTime is not null && task.EndTime is not null)
                            {
                                <span> · @task.StartTime.Value.ToString("HH:mm") – @task.EndTime.Value.ToString("HH:mm")</span>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                @* Erledigte Tasks brauchen keinen Start-Knopf mehr. *@
                @if (!task.IsCompleted)
                {
                    <TaskTimerButton Task="task" OnChanged="HandleTimerChanged" />
                }
                <PriorityIndicator Value="@task.Priority" />
                @if (!isSubTask)
                {
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="() => StartAddSubTask(task.Id)"
                            title="@L["Button_AddSubTask_Title"]">＋</button>
                }
                <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEdit(task)" title="@L["Button_Edit_Title"]">✎</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTaskAsync(task, isSubTask)" title="@L["Button_Delete_Title"]">🗑</button>
            </div>
        </div>
    };

    // Ein Start stoppt ggf. den Timer eines anderen Tasks dieser Liste und ändert
    // dessen Status mit – deshalb die ganze Liste neu laden statt nur den einen Task.
    private async Task HandleTimerChanged(TaskResponseDto _) =>
        tasks = await Api.GetTasksByProjectAsync(Id);

    // ── Abschließen / Zurücksetzen ───────────────────────────────────────────

    // Schnell-Abschluss über die Checkbox: an → "Fertig", aus → zurück auf "Geplant"
    // (bewusst kein Merken des vorherigen Status – konsistent zur Heute-Seite und SubTaskList).
    private async Task ToggleDoneAsync(TaskResponseDto task, bool done)
    {
        var target = done ? WorkStatus.Done : WorkStatus.Planned;
        if (task.Status == target) return;

        if (!await ChangeStatusAsync(task, target))
        {
            await Sound.ErrorAsync();
            return;
        }

        if (done) await Sound.SuccessAsync();
    }

    private async Task<bool> ChangeStatusAsync(TaskResponseDto task, WorkStatus newStatus)
    {
        var dto = new TaskUpdateDto(
            task.Title, task.Description, task.DueDate,
            task.StartTime, task.EndTime, newStatus,
            Enum.Parse<Priority>(task.Priority), task.ProjectId);

        var updated = await Api.UpdateTaskAsync(task.Id, dto);
        if (updated is null || tasks is null) return false;

        var parent = tasks.FirstOrDefault(t => t.Id == task.Id);
        if (parent is not null)
        {
            // Die API liefert beim Update keine Sub-Tasks mit – lokalen Stand erhalten,
            // sonst verschwinden die Sub-Task-Zeilen bis zum nächsten Laden.
            tasks[tasks.IndexOf(parent)] = updated with { SubTasks = parent.SubTasks };
        }
        else
        {
            var parentTask = tasks.FirstOrDefault(t => t.SubTasks?.Any(s => s.Id == task.Id) == true);
            if (parentTask?.SubTasks is not null)
                parentTask.SubTasks[parentTask.SubTasks.IndexOf(parentTask.SubTasks.First(s => s.Id == task.Id))] = updated;
        }

        return true;
    }

    // ── Bearbeiten (geteilter Dialog) ─────────────────────────────────────────

    private void OpenEdit(TaskResponseDto task) => selectedTask = task;

    private void HandleTaskSaved(TaskResponseDto updated)
    {
        if (tasks is null) { selectedTask = null; return; }

        var parentIdx = tasks.FindIndex(t => t.Id == updated.Id);
        if (parentIdx >= 0)
        {
            tasks[parentIdx] = updated;
        }
        else
        {
            var parentTask = tasks.FirstOrDefault(t => t.SubTasks?.Any(s => s.Id == updated.Id) == true);
            if (parentTask?.SubTasks is not null)
            {
                var subIdx = parentTask.SubTasks.FindIndex(s => s.Id == updated.Id);
                if (subIdx >= 0) parentTask.SubTasks[subIdx] = updated;
            }
        }

        selectedTask = null;
    }

    private void HandleTaskDeleted(int id)
    {
        var title = FindTaskTitle(id);

        if (tasks is not null)
        {
            var parentIdx = tasks.FindIndex(t => t.Id == id);
            if (parentIdx >= 0)
            {
                tasks.RemoveAt(parentIdx);
            }
            else
            {
                var parentTask = tasks.FirstOrDefault(t => t.SubTasks?.Any(s => s.Id == id) == true);
                parentTask?.SubTasks?.RemoveAll(s => s.Id == id);
            }
        }

        selectedTask = null;
        ShowTaskUndo(id, title);
    }

    // Live-Aktualisierung (Sub-Tasks geändert) – Dialog bleibt offen, die
    // Sub-Task-Zeilen in der Liste aktualisieren sich mit.
    private void HandleTaskUpdated(TaskResponseDto updated)
    {
        if (tasks is null) return;
        var idx = tasks.FindIndex(t => t.Id == updated.Id);
        if (idx >= 0) tasks[idx] = updated;
    }

    // ── Löschen ──────────────────────────────────────────────────────────────

    private async Task DeleteTaskAsync(TaskResponseDto task, bool isSubTask)
    {
        var success = await Api.DeleteTaskAsync(task.Id);
        if (!success || tasks is null) return;

        if (!isSubTask)
        {
            tasks.Remove(task);
        }
        else
        {
            var parentTask = tasks.FirstOrDefault(t => t.SubTasks?.Any(s => s.Id == task.Id) == true);
            parentTask?.SubTasks?.Remove(task);
        }

        ShowTaskUndo(task.Id, task.Title);
    }

    // Titel eines (Sub-)Tasks aus der aktuellen Liste ermitteln (für den Undo-Toast).
    private string? FindTaskTitle(int id) =>
        tasks?.FirstOrDefault(t => t.Id == id)?.Title
        ?? tasks?.SelectMany(t => t.SubTasks ?? Enumerable.Empty<TaskResponseDto>())
                 .FirstOrDefault(s => s.Id == id)?.Title;

    private void ShowTaskUndo(int id, string? title)
    {
        Toast.ShowUndo(string.IsNullOrWhiteSpace(title) ? "Task gelöscht" : $"{title} gelöscht", async () =>
        {
            if (!await Api.RestoreTaskAsync(id)) return;
            tasks = await Api.GetTasksByProjectAsync(Id);
            await InvokeAsync(StateHasChanged);
        });
    }

    // ── Sub-Task anlegen ─────────────────────────────────────────────────────

    private void StartAddSubTask(int parentId)
    {
        addingSubTaskForId  = parentId;
        subTaskErrorMessage = null;
        newSubTask          = new();
    }

    private void CancelSubTask()
    {
        addingSubTaskForId  = null;
        subTaskErrorMessage = null;
    }

    private async Task CreateSubTaskAsync(int parentId)
    {
        isSaving            = true;
        subTaskErrorMessage = null;

        var dto = new TaskCreateDto(
            newSubTask.Title,
            string.IsNullOrWhiteSpace(newSubTask.Description) ? null : newSubTask.Description,
            newSubTask.DueDate, null, null,
            newSubTask.Priority, Id,
            ParentTaskId: parentId);

        var created = await Api.CreateTaskAsync(dto);
        if (created is not null && tasks is not null)
        {
            var parentTask = tasks.FirstOrDefault(t => t.Id == parentId);
            if (parentTask is not null)
            {
                var updatedSubTasks = (parentTask.SubTasks ?? []).Append(created).ToList();
                tasks[tasks.IndexOf(parentTask)] = parentTask with { SubTasks = updatedSubTasks };
            }
            addingSubTaskForId = null;
            newSubTask         = new();
        }
        else
        {
            subTaskErrorMessage = L["SubTask_Error"];
        }

        isSaving = false;
    }

    // ── Erstellen ────────────────────────────────────────────────────────────

    private void ToggleForm()
    {
        showForm     = !showForm;
        errorMessage = null;
        newTask      = new();
    }

    // Vorlage ins Formular übernehmen. Bereits Getipptes wird bewusst überschrieben –
    // die Auswahl ist eine explizite Aktion des Nutzers.
    private void ApplyTemplate(TaskTemplateResponseDto template)
    {
        newTask.Title       = template.Title;
        newTask.Description = template.Description;
        newTask.Priority    = Enum.Parse<Priority>(template.Priority);
    }

    private async Task CreateTaskAsync()
    {
        isSaving     = true;
        errorMessage = null;

        var dto = new TaskCreateDto(
            newTask.Title,
            string.IsNullOrWhiteSpace(newTask.Description) ? null : newTask.Description,
            newTask.DueDate, newTask.StartTime, newTask.EndTime,
            newTask.Priority, Id);

        var created = await Api.CreateTaskAsync(dto);
        if (created is not null)
        {
            tasks ??= [];
            tasks.Add(created);
            showForm = false;
            newTask  = new();
        }
        else
        {
            errorMessage = L["NewTask_Error"];
        }

        isSaving = false;
    }

    // ── Notizen ──────────────────────────────────────────────────────────────

    private async Task CreateNoteAsync()
    {
        if (noteEditor is not null) await noteEditor.FlushAsync();

        var created = await Api.CreateNoteAsync(new NoteCreateDto("Neue Notiz", null, ProjectId: Id));
        if (created is null || notes is null) return;

        notes.Insert(0, created);
        selectedNote = created;
    }

    private async Task SelectNoteAsync(NoteResponseDto note)
    {
        if (selectedNote?.Id == note.Id) return;
        if (noteEditor is not null) await noteEditor.FlushAsync(); // offene Änderungen sichern
        selectedNote = note;
    }

    private void HandleNoteSaved(NoteResponseDto updated)
    {
        if (notes is null) return;

        var idx = notes.FindIndex(n => n.Id == updated.Id);
        if (idx >= 0) notes[idx] = updated;
        if (selectedNote?.Id == updated.Id) selectedNote = updated;

        StateHasChanged();
    }

    private void HandleNoteDeleted(int id)
    {
        var title = notes?.FirstOrDefault(n => n.Id == id)?.Title;
        notes?.RemoveAll(n => n.Id == id);
        if (selectedNote?.Id == id) selectedNote = null;

        Toast.ShowUndo(string.IsNullOrWhiteSpace(title) ? "Notiz gelöscht" : $"{title} gelöscht", async () =>
        {
            if (!await Api.RestoreNoteAsync(id)) return;
            notes = await Api.GetNotesByProjectAsync(Id) ?? notes;
            await InvokeAsync(StateHasChanged);
        });
    }

    // ── Projekt bearbeiten (ProjectEditDialog) ───────────────────────────────

    private void HandleProjectSavedAsync(ProjectResponseDto saved)
    {
        project           = saved;
        showProjectDialog = false;

        // Geteilten State mitziehen, damit Navigation/Übersicht nicht veralten.
        var all = ProjectState.Projects;
        if (all is not null)
        {
            var idx = all.FindIndex(p => p.Id == saved.Id);
            if (idx >= 0) all[idx] = saved;
            ProjectState.NotifyChanged();
        }
    }

    // ── Formularmodelle ──────────────────────────────────────────────────────

    private class TaskCreateFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Titel ist erforderlich.")]
        [System.ComponentModel.DataAnnotations.MaxLength(300)]
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public DateTime? DueDate { get; set; }
        public DateTime? StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public Priority Priority { get; set; } = Priority.Medium;
        public WorkStatus Status { get; set; } = WorkStatus.Planned;
    }

}
