@page "/tasks/{Id:int}"
@inject ApiService Api
@inject NavigationManager Nav
@inject IStringLocalizer<Enums> EnumL
@inject ToastService Toast

<PageTitle>@(task?.Title ?? "Task") – HorizonNET</PageTitle>

@if (loading)
{
    <p>Wird geladen…</p>
}
else if (task is null)
{
    <p class="text-muted">Task nicht gefunden.</p>
    <a href="" class="btn btn-outline-secondary btn-sm">Zur Übersicht</a>
}
else
{
    @if (task.ParentTaskId is int parentId)
    {
        <a href="@($"tasks/{parentId}")" class="d-inline-block mb-2 text-decoration-none">← Zum Eltern-Task</a>
    }

    @* Reine Ansicht: Die Task-Felder werden angezeigt, nicht bearbeitet. Bearbeitet
       wird über den TaskEditDialog (Bearbeiten-Button) – dadurch ist das Layout hier
       vom Editor entkoppelt. Notizen, Sub-Tasks und Zeiterfassung bleiben eigene,
       interaktive Bereiche. *@
    <div class="row g-4">
        @* Hauptbereich *@
        <div class="col-lg-8">
            <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                <div class="d-flex align-items-center gap-2">
                    <PriorityIndicator Value="@task.Priority" />
                    <h1 class="h3 mb-0">@task.Title</h1>
                </div>
                <div class="d-flex gap-2 flex-shrink-0">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="OpenEdit">Bearbeiten</button>
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DeleteAsync">Löschen</button>
                </div>
            </div>

            <div class="mb-3">
                <span class="badge @StatusBadgeClass(task.Status)">@EnumL[$"WorkStatus_{task.Status}"]</span>
            </div>

            <label class="form-label text-muted small mb-1">Beschreibung</label>
            @if (!string.IsNullOrWhiteSpace(task.Description))
            {
                <p class="task-detail-description mb-0">@task.Description</p>
            }
            else
            {
                <p class="text-muted fst-italic mb-0">Keine Beschreibung.</p>
            }

            @* Sub-Tasks direkt unter der Beschreibung – nur bei Haupt-Tasks. *@
            @if (task.ParentTaskId is null)
            {
                <hr class="my-3" />
                <SubTaskList ParentTaskId="task.Id" ProjectId="task.ProjectId"
                             SubTasks="task.SubTasks" SubTasksChanged="HandleSubTasksChanged" />
            }

            @* Notizen zu diesem Task (Phase 2b). *@
            <hr class="my-3" />
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="fw-semibold">Notizen</div>
                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="CreateNoteAsync">
                    + Neue Notiz
                </button>
            </div>

            @if (notes is null)
            {
                <p class="text-muted small mb-0">Wird geladen…</p>
            }
            else
            {
                @if (notes.Count > 0)
                {
                    <div class="task-notes-list border rounded mb-3">
                        <NoteList Notes="notes" SelectedId="selectedNote?.Id" OnSelect="SelectNoteAsync" />
                    </div>
                }
                else if (selectedNote is null)
                {
                    <p class="text-muted small">Noch keine Notizen zu diesem Task.</p>
                }

                @if (selectedNote is not null)
                {
                    <div class="task-note-editor border rounded p-2">
                        <NoteEditor @ref="noteEditor" Note="selectedNote"
                                    OnSaved="HandleNoteSaved" OnDeleted="HandleNoteDeleted" />
                    </div>
                }
            }
        </div>

        @* Sidebar: Eigenschaften als Anzeige *@
        <div class="col-lg-4">
            <div class="card">
                <div class="card-body d-flex flex-column gap-3">
                    <div>
                        <label class="form-label small text-muted mb-1">Priorität</label>
                        <div>@PriorityDisplay.Symbol(Prio) @EnumL[$"Priority_{Prio}"]</div>
                    </div>
                    <div>
                        <label class="form-label small text-muted mb-1">Projekt</label>
                        <div>
                            @if (task.ProjectId is int projectId)
                            {
                                <a href="@($"projects/{projectId}")">@(task.ProjectName ?? "Projekt")</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </div>
                    </div>
                    <div>
                        <label class="form-label small text-muted mb-1">Fällig</label>
                        <div>
                            @if (task.DueDate is DateTime due)
                            {
                                <span>@due.ToString("dd.MM.yyyy")</span>
                                @if (task.StartTime is DateTime st && task.EndTime is DateTime et)
                                {
                                    <span class="text-muted"> · @st.ToString("HH:mm")–@et.ToString("HH:mm")</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </div>
                    </div>

                    @* Optionale Felder nur zeigen, wenn gesetzt – hinzugefügt/entfernt wird im Dialog. *@
                    @if (TaskLink.IsValid(task.Link))
                    {
                        <div>
                            <label class="form-label small text-muted mb-1">Link</label>
                            <div class="text-truncate">
                                <a href="@task.Link" target="_blank" rel="noopener noreferrer"
                                   title="@task.Link">@task.Link ↗</a>
                            </div>
                        </div>
                    }
                    @if (task.WaitingFor is not null)
                    {
                        <div>
                            <label class="form-label small text-muted mb-1">Warten auf</label>
                            <div>⏳ @task.WaitingFor</div>
                        </div>
                    }

                    <div>
                        <label class="form-label small text-muted mb-1">Google-Kalender</label>
                        <div>
                            @if (task.IsSyncedToGoogle)
                            {
                                <span class="badge" style="background-color:#4285F4;">Im Google-Kalender</span>
                            }
                            else
                            {
                                <span class="text-muted">Nicht synchronisiert</span>
                            }
                        </div>
                    </div>

                    @* Zeiterfassung: Start/Stop plus die einzelnen Intervalle (bleibt interaktiv). *@
                    <div class="border-top pt-3">
                        <label class="form-label small text-muted mb-1">Zeiterfassung</label>
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                            <TaskTimerButton Task="task" OnChanged="HandleTimerChangedAsync" />
                            <span class="fw-semibold" title="Gesamte erfasste Zeit">
                                @TimeDisplay.Short(task.TrackedTotal(DateTime.Now))
                            </span>
                        </div>

                        @if (timeEntries is { Count: > 0 })
                        {
                            <ul class="list-unstyled small text-muted mb-0 task-time-entries">
                                @foreach (var entry in timeEntries)
                                {
                                    <li class="d-flex justify-content-between gap-2">
                                        <span>
                                            @entry.StartedAt.ToString("dd.MM. HH:mm")
                                            –
                                            @(entry.EndedAt?.ToString("HH:mm") ?? "läuft")
                                        </span>
                                        <span>
                                            @(entry.EndedAt is null
                                                ? TimeDisplay.Clock(DateTime.Now - entry.StartedAt)
                                                : TimeDisplay.Clock(TimeSpan.FromSeconds(entry.Seconds)))
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="small text-muted">Noch keine Zeit erfasst.</div>
                        }
                    </div>

                    <div class="border-top pt-2 small text-muted">
                        <div>Erstellt: @task.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                        <div>Geändert: @task.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </div>
            </div>

            @if (actionError is not null)
            {
                <div class="alert alert-danger py-1 mt-3 mb-0">@actionError</div>
            }
        </div>
    </div>

    @* Bearbeiten läuft über den geteilten Dialog – gleiche Komponente wie Board/Übersicht. *@
    <TaskEditDialog Visible="editDialogVisible"
                    Task="task"
                    OnSaved="HandleTaskSaved"
                    OnDeleted="HandleTaskDeleted"
                    OnTaskUpdated="HandleTaskUpdated"
                    OnClose="CloseEdit" />
}

@code {
    [Parameter] public int Id { get; set; }

    private TaskResponseDto? task;
    private bool loading = true;
    private string? actionError;
    private int? loadedId;

    // Bearbeiten-Dialog (geteilte Komponente).
    private bool editDialogVisible;

    // Priorität als Enum für die Anzeige (Response liefert sie als String).
    private Priority Prio => Enum.Parse<Priority>(task!.Priority);

    // Notizen zu diesem Task
    private List<NoteListItemDto>? notes;
    private NoteResponseDto? selectedNote;
    private NoteEditor? noteEditor;

    // Zeiterfassung: die einzelnen Intervalle (neueste zuerst).
    private List<TimeEntryResponseDto>? timeEntries;

    // OnParametersSetAsync statt OnInitializedAsync: lädt neu, wenn zwischen zwei
    // Tasks navigiert wird (gleiche Komponenteninstanz, nur anderer Parameter).
    protected override async Task OnParametersSetAsync()
    {
        if (loadedId == Id) return;

        // Vor dem Wechsel offene Notiz-Änderungen des bisherigen Tasks sichern.
        if (noteEditor is not null) await noteEditor.FlushAsync();

        loadedId     = Id;
        loading      = true;
        actionError  = null;
        notes        = null;
        selectedNote = null;
        timeEntries  = null;

        task = await Api.GetTaskAsync(Id);
        if (task is not null)
        {
            notes       = await Api.GetNotesByTaskAsync(Id) ?? new();
            timeEntries = await Api.GetTimeEntriesAsync(Id) ?? new();
        }

        loading = false;
    }

    // Farbe des Status-Badges – dezente Zuordnung, damit der Zustand auf einen Blick lesbar ist.
    private static string StatusBadgeClass(WorkStatus status) => status switch
    {
        WorkStatus.Done         => "text-bg-success",
        WorkStatus.Abandoned    => "text-bg-secondary",
        WorkStatus.InProgress   => "text-bg-primary",
        WorkStatus.Paused       => "text-bg-warning",
        _                       => "text-bg-light",
    };

    // ── Bearbeiten-Dialog ──────────────────────────────────────────────────────

    private void OpenEdit() => editDialogVisible = true;

    private void CloseEdit() => editDialogVisible = false;

    private void HandleTaskSaved(TaskResponseDto saved)
    {
        task = saved;
        editDialogVisible = false;
    }

    // Live-Aktualisierung (Sub-Tasks im Dialog geändert) – Dialog bleibt offen.
    private void HandleTaskUpdated(TaskResponseDto updated) => task = updated;

    private void HandleTaskDeleted(int id)
    {
        var title = task?.Title ?? "Task";
        var projectId = task?.ProjectId;
        editDialogVisible = false;
        NavigateAwayAfterDelete(projectId, id, title);
    }

    // Nach Start/Stop: Task und Intervalle frisch holen. Der Status hat sich
    // mitgeändert („In Arbeit" bzw. „Pausiert").
    private async Task HandleTimerChangedAsync(TaskResponseDto updated)
    {
        task        = updated;
        timeEntries = await Api.GetTimeEntriesAsync(Id) ?? new();
    }

    private async Task DeleteAsync()
    {
        if (task is null) return;

        var id        = task.Id;
        var title     = task.Title;
        var projectId = task.ProjectId;

        if (!await Api.DeleteTaskAsync(id))
        {
            actionError = "Löschen fehlgeschlagen.";
            return;
        }

        NavigateAwayAfterDelete(projectId, id, title);
    }

    // Nach dem Löschen zurück zum Projekt (bzw. zur Übersicht) und Undo anbieten.
    private void NavigateAwayAfterDelete(int? projectId, int id, string title)
    {
        Nav.NavigateTo(projectId is int pid ? $"projects/{pid}" : "");

        Toast.ShowUndo($"{title} gelöscht", async () =>
        {
            if (await Api.RestoreTaskAsync(id))
                Nav.NavigateTo($"tasks/{id}");
        });
    }

    // Live-Aktualisierung aus der SubTaskList (wirkt sofort über die API).
    private void HandleSubTasksChanged(List<TaskResponseDto> updated) =>
        task = task is null ? null : task with { SubTasks = updated.Count > 0 ? updated : null };

    // ── Notizen ──────────────────────────────────────────────────────────────

    private async Task CreateNoteAsync()
    {
        if (noteEditor is not null) await noteEditor.FlushAsync();

        // Neue Notiz direkt mit Task UND dessen Projekt verknüpfen – die Zuordnung ist
        // sonst nur halb gesetzt (Task ja, Projekt nein), obwohl der Task zu einem
        // Projekt gehört.
        var created = await Api.CreateNoteAsync(
            new NoteCreateDto("Neue Notiz", null, TaskItemId: Id, ProjectId: task?.ProjectId));
        if (created is null || notes is null) return;

        notes.Insert(0, NoteListItemDto.From(created));
        selectedNote = created;
    }

    private async Task SelectNoteAsync(NoteListItemDto note)
    {
        if (selectedNote?.Id == note.Id) return;
        if (noteEditor is not null) await noteEditor.FlushAsync(); // offene Änderungen sichern
        selectedNote = await Api.GetNoteAsync(note.Id);            // volle Notiz inkl. Content laden
    }

    private void HandleNoteSaved(NoteResponseDto updated)
    {
        if (notes is null) return;
        var idx = notes.FindIndex(n => n.Id == updated.Id);
        if (idx >= 0) notes[idx] = NoteListItemDto.From(updated);
        if (selectedNote?.Id == updated.Id) selectedNote = updated;
    }

    private void HandleNoteDeleted(int id)
    {
        var title = notes?.FirstOrDefault(n => n.Id == id)?.Title;
        notes?.RemoveAll(n => n.Id == id);
        if (selectedNote?.Id == id) selectedNote = null;

        Toast.ShowUndo(string.IsNullOrWhiteSpace(title) ? "Notiz gelöscht" : $"{title} gelöscht", async () =>
        {
            if (!await Api.RestoreNoteAsync(id)) return;
            notes = await Api.GetNotesByTaskAsync(Id) ?? notes;
            await InvokeAsync(StateHasChanged);
        });
    }
}
