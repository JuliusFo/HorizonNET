@page "/settings"
@inject SettingsState AppSettings
@inject ApiService Api
@inject IConfiguration Config
@inject VersionState Version

<PageTitle>Einstellungen – HorizonNET</PageTitle>

<h1 class="mb-4">Einstellungen</h1>

<div class="card mb-3 settings-card">
    <div class="card-header fw-semibold">Allgemein</div>
    <div class="card-body">
        <label for="calView" class="form-label">Standard-Ansicht im Kalender</label>
        <select id="calView" class="form-select" style="max-width: 16rem;"
                value="@AppSettings.CalendarDefaultView"
                @onchange="OnCalendarViewChanged">
            <option value="0">Tag</option>
            <option value="1">Woche</option>
            <option value="2">Monat</option>
        </select>
        <div class="form-text">Wird beim Öffnen des Kalenders vorausgewählt.</div>

        <div class="form-check form-switch mt-3">
            <input class="form-check-input" type="checkbox" id="soundsToggle"
                   checked="@AppSettings.SoundsEnabled" @onchange="OnSoundsChanged" />
            <label class="form-check-label" for="soundsToggle">Sound-Effekte</label>
        </div>
        <div class="form-text">Kurze Töne bei erledigten Tasks und Daily Tasks.</div>
    </div>
</div>

<div class="card mb-3 settings-card">
    <div class="card-header fw-semibold">Task-Vorlagen</div>
    <div class="card-body">
        <p class="text-muted">
            Vorlagen für wiederkehrende Aufgaben. Beim Anlegen eines Tasks lassen sie sich
            auswählen und belegen Titel, Beschreibung, Priorität und Projekt vor.
        </p>
        <TaskTemplateManager />
    </div>
</div>

<div class="card mb-3 settings-card">
    <div class="card-header fw-semibold">Google-Kalender</div>
    <div class="card-body">
        <p class="text-muted">
            Verbinde dein Google-Konto, um Termine aus deinem Google-Kalender anzuzeigen
            und geplante Tasks dorthin zu schreiben.
        </p>

        @if (GoogleResult == "connected")
        {
            <div class="alert alert-success py-2">Google-Konto erfolgreich verbunden.</div>
        }
        else if (GoogleResult == "noscope")
        {
            <div class="alert alert-warning py-2">
                Der <strong>Kalenderzugriff</strong> wurde nicht erteilt. Bitte erneut verbinden und
                auf dem Google-Zustimmungsbildschirm die <strong>Kalender-Berechtigung</strong> ankreuzen.
            </div>
        }
        else if (GoogleResult == "error")
        {
            <div class="alert alert-danger py-2">Verbindung fehlgeschlagen. Bitte erneut versuchen.</div>
        }

        @if (status is null)
        {
            <p class="text-muted mb-0">Status wird geladen…</p>
        }
        else if (status.Connected)
        {
            <div class="mb-3">
                <span class="badge bg-success">Verbunden</span>
                @if (!string.IsNullOrEmpty(status.Email))
                {
                    <span class="ms-2">@status.Email</span>
                }
            </div>
            <button type="button" class="btn btn-outline-danger" @onclick="DisconnectAsync" disabled="@busy">
                Verbindung trennen
            </button>
        }
        else
        {
            <div class="mb-3">
                <span class="badge bg-secondary">Nicht verbunden</span>
            </div>
            <a class="btn btn-primary" href="@ConnectUrl">Mit Google verbinden</a>
        }
    </div>
</div>

<div class="card settings-card">
    <div class="card-header fw-semibold">Über</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4 fw-normal text-muted">Client-Version</dt>
            <dd class="col-sm-8">@Version.ClientVersionShort</dd>

            <dt class="col-sm-4 fw-normal text-muted">API-Version</dt>
            <dd class="col-sm-8 mb-0">
                @if (Version.ApiVersionShort is { } v)
                {
                    <span>@v</span>
                    @if (Version.ApiVersion?.BuildUtc is { } built)
                    {
                        <span class="text-muted"> · Build @built.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    }
                }
                else
                {
                    <span class="text-muted">nicht erreichbar</span>
                }
            </dd>
        </dl>
    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "google")]
    public string? GoogleResult { get; set; }

    private GoogleStatusDto? status;
    private bool busy;

    // Vollständige Navigation zur API (anderer Origin), die den OAuth-Flow startet.
    private string ConnectUrl =>
        $"{(Config["ApiSettings:BaseUrl"] ?? string.Empty).TrimEnd('/')}/api/google/connect";

    protected override async Task OnInitializedAsync()
    {
        await AppSettings.EnsureLoadedAsync();
        await Version.EnsureApiLoadedAsync();
        status = await Api.GetGoogleStatusAsync();
    }

    private async Task OnCalendarViewChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var index))
            await AppSettings.SetCalendarDefaultViewAsync(index);
    }

    private async Task OnSoundsChanged(ChangeEventArgs e)
    {
        if (e.Value is bool enabled)
            await AppSettings.SetSoundsEnabledAsync(enabled);
    }

    private async Task DisconnectAsync()
    {
        busy = true;
        await Api.DisconnectGoogleAsync();
        status = await Api.GetGoogleStatusAsync();
        busy = false;
    }
}
