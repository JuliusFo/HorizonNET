@* Reine Notizliste: Auswahl per Klick. Suche/Filter bleiben beim Aufrufer,
   damit die Liste sowohl auf der Notizen-Seite als auch am Task wiederverwendbar ist. *@
<div class="note-list">
    @if (Notes.Count == 0)
    {
        <div class="note-list-empty text-muted">@EmptyText</div>
    }
    else
    {
        @foreach (var n in Notes)
        {
            <button type="button" class="note-list-item @(SelectedId == n.Id ? "active" : "")"
                    @onclick="() => OnSelect.InvokeAsync(n)">
                <div class="note-list-title">@(string.IsNullOrWhiteSpace(n.Title) ? "(ohne Titel)" : n.Title)</div>
                @{
                    var snippet = Snippet(n.Content);
                }
                @if (snippet.Length > 0)
                {
                    <div class="note-list-snippet">@snippet</div>
                }
                <div class="note-list-meta">
                    @if (n.TaskItemTitle is not null)
                    {
                        <span class="note-list-tag">🗒 @n.TaskItemTitle</span>
                    }
                    @if (n.ProjectName is not null)
                    {
                        <span class="note-list-tag">📁 @n.ProjectName</span>
                    }
                    <span class="note-list-date">@n.UpdatedAt.ToString("dd.MM.yy HH:mm")</span>
                </div>
            </button>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public List<NoteResponseDto> Notes { get; set; } = new();
    [Parameter] public int? SelectedId { get; set; }
    [Parameter] public EventCallback<NoteResponseDto> OnSelect { get; set; }
    [Parameter] public string EmptyText { get; set; } = "Keine Notizen.";

    // HTML grob zu Klartext für eine kurze Vorschau in der Liste.
    private static string Snippet(string? html)
    {
        if (string.IsNullOrEmpty(html)) return string.Empty;
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ").Trim();
        return text.Length > 120 ? text[..120] + "…" : text;
    }
}
