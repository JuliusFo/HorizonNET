@* Reine Notizliste: Auswahl per Klick. Suche/Filter bleiben beim Aufrufer,
   damit die Liste sowohl auf der Notizen-Seite als auch am Task wiederverwendbar ist. *@
<div class="note-list">
    @if (Notes.Count == 0)
    {
        <div class="note-list-empty text-muted">@EmptyText</div>
    }
    else
    {
        @foreach (var n in Notes)
        {
            <button type="button" class="note-list-item @(Compact ? "compact" : "") @(SelectedId == n.Id ? "active" : "")"
                    @onclick="() => OnSelect.InvokeAsync(n)">
                <div class="note-list-title">
                    @if (n.Kind == NoteKind.Drawing)
                    {
                        <span class="note-list-kind" title="Zeichnung" aria-hidden="true">✏️</span>
                    }
                    @(string.IsNullOrWhiteSpace(n.Title) ? "(ohne Titel)" : n.Title)
                </div>

                @* Im schlanken Modus bleibt nur der Titel: Im Ordnerbaum sagen Vorschau,
                   Task- und Projekt-Marke nichts, was der Pfad darüber nicht schon zeigt –
                   sie machen die Einrückung nur unlesbar. *@
                @if (!Compact)
                {
                    @* Zeichnung: Vorschaubild statt Text-Snippet (das SVG liegt nicht in der Liste). *@
                    @if (n.Kind == NoteKind.Drawing)
                    {
                        @if (!string.IsNullOrEmpty(n.Thumbnail))
                        {
                            <img class="note-list-thumb" src="@n.Thumbnail" alt="" />
                        }
                    }
                    else if (!string.IsNullOrEmpty(n.Snippet))
                    {
                        <div class="note-list-snippet">@n.Snippet</div>
                    }
                    <div class="note-list-meta">
                        @if (n.TaskItemTitle is not null)
                        {
                            <span class="note-list-tag">🗒 @n.TaskItemTitle</span>
                        }
                        @if (n.ProjectName is not null)
                        {
                            <span class="note-list-tag">📁 @n.ProjectName</span>
                        }
                        <span class="note-list-date">@n.UpdatedAt.ToString("dd.MM.yy HH:mm")</span>
                    </div>
                }
            </button>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public List<NoteListItemDto> Notes { get; set; } = new();
    [Parameter] public int? SelectedId { get; set; }
    [Parameter] public EventCallback<NoteListItemDto> OnSelect { get; set; }
    [Parameter] public string EmptyText { get; set; } = "Keine Notizen.";

    // Schlank = nur der Titel. Für den Ordnerbaum, wo der Pfad die Zuordnung schon zeigt.
    // Die flache Trefferliste der Suche bleibt bewusst ausführlich: Dort fehlt der Baum
    // als Kontext, und wer im Text sucht, will den Treffer im Ausschnitt sehen.
    [Parameter] public bool Compact { get; set; }
}
