@inject ApiService Api
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Editor für eine Zeichnungs-Notiz (Kind == Drawing). Aufbau wie NoteEditor: gleicher
   Titel-Balken, gleiche Projekt-/Task-Zuordnung, gleicher Tab-Lock (noteLock.js). Statt
   des HTML-Editors zeichnet js-draw ins Canvas; gespeichert wird das SVG.
   Auto-Save taktet anders als bei Text: erst ~5 s nach dem letzten Strich, weil bei jedem
   Speichern das komplette SVG über die Leitung geht. *@
@if (loaded is null)
{
    <div class="note-empty text-muted">Keine Zeichnung ausgewählt.</div>
}
else
{
    <div class="note-editor">
        @if (readOnly)
        {
            <div class="alert alert-warning d-flex align-items-center gap-3 py-2 mb-2">
                <span class="flex-grow-1">Diese Zeichnung wird gerade in einem anderen Tab bearbeitet.</span>
                <button type="button" class="btn btn-sm btn-warning flex-shrink-0" @onclick="TakeOverAsync">
                    Bearbeitung hier übernehmen
                </button>
            </div>
        }

        <div class="note-editor-bar">
            <input class="form-control form-control-lg fw-semibold note-editor-title"
                   placeholder="Titel…" value="@title" @oninput="OnTitleInput" disabled="@readOnly" />
            <span class="note-editor-status">@StatusText</span>
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="DeleteAsync"
                    disabled="@readOnly" title="Zeichnung löschen">🗑</button>
        </div>

        <div class="note-editor-meta">
            <ProjectSelect @bind-Value="selectedProjectId" Change="OnProjectChanged" Disabled="readOnly" />

            <RadzenDropDown TValue="int?" Data="taskOptions" TextProperty="Label" ValueProperty="Id"
                            @bind-Value="selectedTaskId" Change="OnAssignmentChanged"
                            AllowFiltering="true" AllowClear="true" Disabled="readOnly"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="— kein Task —" class="note-assign-task" />

            <span class="text-muted ms-auto">Geändert: @loaded.UpdatedAt.ToString("dd.MM.yyyy HH:mm:ss")</span>
        </div>

        @if (readOnly)
        {
            @* Read-only: SVG einfach als Bild anzeigen (kein js-draw). *@
            <div class="drawing-readonly">@((MarkupString)content)</div>
        }
        else
        {
            @* Leerer Host – js-draw befüllt ihn per Interop. Bewusst OHNE Razor-Kindinhalt,
               damit Blazors DOM-Diffing das von js-draw erzeugte DOM nicht anfasst. *@
            <div class="drawing-host" @ref="canvasHost"></div>
        }
    </div>
}

@code {
    // Aktuell zu bearbeitende Zeichnung; null = nichts ausgewählt.
    [Parameter] public NoteResponseDto? Note { get; set; }

    // Nach erfolgreichem Speichern (für Listenaktualisierung beim Aufrufer).
    [Parameter] public EventCallback<NoteResponseDto> OnSaved { get; set; }

    // Nach dem Löschen.
    [Parameter] public EventCallback<int> OnDeleted { get; set; }

    private NoteResponseDto? loaded;      // Snapshot der geladenen Zeichnung (Save-Ziel)
    private string title = string.Empty;
    private string content = string.Empty; // zuletzt geladenes/gespeichertes SVG (nur Read-only-Anzeige)
    private SaveState state = SaveState.Saved;
    private DateTime? savedAt;
    private CancellationTokenSource? debounceCts;

    // js-draw-Interop
    private ElementReference canvasHost;
    private IJSObjectReference? drawingModule;
    private bool needsInit;   // beim nächsten OnAfterRender einen Editor in canvasHost erzeugen
    private bool editorActive; // ist aktuell ein js-draw-Editor am Host aktiv?

    // Tab-Lock (identisch zu NoteEditor – noteLock.js ist generisch über die Note-Id).
    private IJSObjectReference? lockModule;
    private DotNetObjectReference<DrawingEditor>? selfRef;
    private bool readOnly;

    // Zuordnung (Projekt/Task)
    private int? selectedProjectId;
    private int? selectedTaskId;
    private List<TaskResponseDto> allTasks = new();
    private List<TaskOption> taskOptions = new();

    private record TaskOption(int Id, string Label);

    private static readonly StringComparer NameComparer = StringComparer.CurrentCultureIgnoreCase;

    private enum SaveState { Saved, Pending, Saving, Error }

    private string StatusText => state switch
    {
        SaveState.Pending => "Nicht gespeichert…",
        SaveState.Saving  => "Speichert…",
        SaveState.Error   => "Fehler beim Speichern",
        _ when savedAt is DateTime at => $"Gespeichert um {at:HH:mm:ss}",
        _                 => "Gespeichert"
    };

    protected override async Task OnInitializedAsync()
    {
        allTasks = await Api.GetTasksAsync() ?? new();
        RebuildTaskOptions();
    }

    private void RebuildTaskOptions()
    {
        var source = selectedProjectId is int projectId
            ? allTasks.Where(t => t.ProjectId == projectId)
            : allTasks;

        taskOptions = new();
        foreach (var t in source.OrderBy(t => t.Title, NameComparer))
        {
            taskOptions.Add(new TaskOption(t.Id, t.Title));
            if (t.SubTasks is not null)
                foreach (var s in t.SubTasks.OrderBy(s => s.Title, NameComparer))
                    taskOptions.Add(new TaskOption(s.Id, "↳ " + s.Title));
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Note is null)
        {
            var prev = loaded?.Id;
            await DestroyEditorAsync();
            loaded = null;
            await ReleaseLockAsync(prev);
            return;
        }

        if (loaded?.Id == Note.Id) return;

        // Wechsel auf eine andere Zeichnung: erst sichern, dann den alten Editor abbauen.
        await FlushAsync();
        await DestroyEditorAsync();

        loaded            = Note;
        title             = Note.Title;
        content           = Note.Content ?? string.Empty;
        selectedProjectId = Note.ProjectId;
        selectedTaskId    = Note.TaskItemId;
        state             = SaveState.Saved;
        savedAt           = null;
        RebuildTaskOptions();

        await AcquireLockAsync(force: false);

        // Nur wenn wir schreiben dürfen, einen js-draw-Editor aufbauen (sonst Bild-Anzeige).
        needsInit = !readOnly;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!needsInit || loaded is null || readOnly) return;
        needsInit = false;

        drawingModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/drawingEditor.js");
        selfRef       ??= DotNetObjectReference.Create(this);

        await drawingModule.InvokeVoidAsync("init", canvasHost, content, selfRef);
        editorActive = true;
    }

    // ── js-draw meldet eine Änderung ────────────────────────────────────────────

    [JSInvokable]
    public Task OnDrawingChanged()
    {
        ScheduleSave();
        return Task.CompletedTask;
    }

    // ── Tab-Lock (wie NoteEditor) ───────────────────────────────────────────────

    private async Task AcquireLockAsync(bool force)
    {
        if (loaded is null) return;

        lockModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/noteLock.js");
        selfRef    ??= DotNetObjectReference.Create(this);

        var acquired = await lockModule.InvokeAsync<bool>("acquire", loaded.Id, selfRef, force);
        readOnly = !acquired;
    }

    private async Task ReleaseLockAsync(int? noteId)
    {
        readOnly = false;
        if (lockModule is null) return;
        try { await lockModule.InvokeVoidAsync("release", noteId); }
        catch (JSDisconnectedException) { }
    }

    // Ein anderer Tab hat übernommen: ausstehende Änderungen verwerfen, Editor abbauen.
    [JSInvokable]
    public async Task OnLockLost()
    {
        debounceCts?.Cancel();
        await DestroyEditorAsync();
        readOnly = true;
        state = SaveState.Saved;
        await InvokeAsync(StateHasChanged);
    }

    private async Task TakeOverAsync()
    {
        if (loaded is null) return;

        var fresh = await Api.GetNoteAsync(loaded.Id);
        if (fresh is null) return;

        loaded            = fresh;
        title             = fresh.Title;
        content           = fresh.Content ?? string.Empty;
        selectedProjectId = fresh.ProjectId;
        selectedTaskId    = fresh.TaskItemId;
        state             = SaveState.Saved;
        savedAt           = null;
        RebuildTaskOptions();

        await AcquireLockAsync(force: true);
        needsInit = !readOnly;   // OnAfterRender baut den Editor (neu) auf
        await InvokeAsync(StateHasChanged);
    }

    // ── Zuordnung / Titel ───────────────────────────────────────────────────────

    private void OnAssignmentChanged() => ScheduleSave();

    private void OnProjectChanged()
    {
        RebuildTaskOptions();
        if (selectedTaskId is int taskId && taskOptions.All(o => o.Id != taskId))
            selectedTaskId = null;
        ScheduleSave();
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        title = e.Value?.ToString() ?? string.Empty;
        ScheduleSave();
    }

    // ── Auto-Save ───────────────────────────────────────────────────────────────

    private void ScheduleSave()
    {
        if (readOnly) return;

        state = SaveState.Pending;
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        _ = DebouncedSaveAsync(debounceCts.Token);
    }

    private async Task DebouncedSaveAsync(CancellationToken token)
    {
        try
        {
            // Längerer Ruhe-Debounce als bei Text: ein SVG ist deutlich größer.
            await Task.Delay(5000, token);
            await SaveAsync();
        }
        catch (TaskCanceledException) { /* durch neue Änderung ersetzt */ }
    }

    public async Task FlushAsync()
    {
        if (loaded is not null && !readOnly && state is SaveState.Pending or SaveState.Error)
            await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (loaded is null || readOnly || drawingModule is null || !editorActive) return;

        debounceCts?.Cancel();
        state = SaveState.Saving;
        await InvokeAsync(StateHasChanged);

        // SVG + Thumbnail erst jetzt aus js-draw holen (nicht bei jeder Änderung).
        var svg = await drawingModule.InvokeAsync<string?>("getSvg", canvasHost);
        if (svg is null)
        {
            state = SaveState.Error;
            await InvokeAsync(StateHasChanged);
            return;
        }
        var thumbnail = await drawingModule.InvokeAsync<string?>("getThumbnail", canvasHost);

        var dto = new NoteUpdateDto(title.Trim(), svg, selectedTaskId, selectedProjectId, thumbnail);
        var updated = await Api.UpdateNoteAsync(loaded.Id, dto);

        if (updated is null)
        {
            state = SaveState.Error;
            await InvokeAsync(StateHasChanged);
            return;
        }

        loaded  = updated;
        content = svg;
        state   = SaveState.Saved;
        savedAt = updated.UpdatedAt;
        await OnSaved.InvokeAsync(updated);
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteAsync()
    {
        if (loaded is null || readOnly) return;

        debounceCts?.Cancel();
        var id = loaded.Id;
        var ok = await Api.DeleteNoteAsync(id);
        if (!ok) return;

        await DestroyEditorAsync();
        loaded = null;
        await ReleaseLockAsync(id);
        await OnDeleted.InvokeAsync(id);
    }

    private async Task DestroyEditorAsync()
    {
        if (!editorActive || drawingModule is null) return;
        editorActive = false;
        try { await drawingModule.InvokeVoidAsync("destroy", canvasHost); }
        catch (JSDisconnectedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        debounceCts?.Cancel();
        await FlushAsync();
        debounceCts?.Dispose();

        await DestroyEditorAsync();
        await ReleaseLockAsync(loaded?.Id);

        if (drawingModule is not null)
        {
            try { await drawingModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
        if (lockModule is not null)
        {
            try { await lockModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }

        selfRef?.Dispose();
    }
}
