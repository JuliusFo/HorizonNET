@* Abgeleiteter Ordnerbaum der Notizen (Projekte → Arbeitsbereich → Projekt → Task).
   Die Blätter rendern die vorhandene NoteList weiter – dadurch sehen Auswahl, Snippet
   und Zeichnungs-Vorschau aus wie in der flachen Liste, und die Komponente bleibt an
   den anderen Einsatzorten (Task- und Projekt-Detailseite) unangetastet.

   Die Komponente ruft sich für Unterebenen selbst auf. Der Aufklapp-Zustand wird als
   Menge der ZUGEklappten Schlüssel durchgereicht: leer = alles offen, was bei wenigen
   Notizen der freundlichere Startzustand ist. Gemerkt wird er bewusst nicht. *@
@foreach (var node in Nodes)
{
    var offen = !Collapsed.Contains(node.Key);

    <div class="note-tree-node" @key="node.Key">
        @* Aktionen liegen NEBEN dem Schalter, nicht darin: Ein Button im Button wäre
           ungültiges HTML und der Klick landete beim falschen Ziel. *@
        <div class="note-tree-row">
            <button type="button" class="note-tree-folder"
                    style="padding-left:@(FormattableString.Invariant($"{0.4 + Depth * 0.85:0.##}"))rem"
                    @onclick="() => Toggle(node.Key)"
                    title="@node.Label">
                <span class="note-tree-chevron" aria-hidden="true">@(offen ? "▾" : "▸")</span>
                <span class="note-tree-icon" aria-hidden="true">@Icon(node.Kind)</span>
                <span class="note-tree-label text-truncate">@node.Label</span>
                <span class="note-tree-count">@NoteTreeBuilder.CountNotes(node)</span>
            </button>
            @NodeActions?.Invoke(node)
        </div>

        @if (offen)
        {
            @* Notizen direkt in diesem Ordner (z. B. am Projekt statt am Task). *@
            @if (node.Notes.Count > 0)
            {
                <div class="note-tree-notes"
                     style="padding-left:@(FormattableString.Invariant($"{0.4 + (Depth + 1) * 0.85:0.##}"))rem">
                    <NoteList Notes="node.Notes" SelectedId="SelectedId" OnSelect="OnSelect" Compact="true" />
                </div>
            }

            @if (node.Children.Count > 0)
            {
                <NoteTree Nodes="node.Children" Depth="Depth + 1" Collapsed="Collapsed"
                          SelectedId="SelectedId" OnSelect="OnSelect" NodeActions="NodeActions" />
            }
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public List<NoteTreeBuilder.Node> Nodes { get; set; } = new();

    // Zugeklappte Schlüssel – geteilt über alle Ebenen, damit der Zustand beim
    // Auf-/Zuklappen einer Ebene nicht die anderen zurücksetzt.
    [Parameter, EditorRequired] public HashSet<string> Collapsed { get; set; } = new();

    [Parameter] public int Depth { get; set; }
    [Parameter] public int? SelectedId { get; set; }
    [Parameter] public EventCallback<NoteListItemDto> OnSelect { get; set; }

    // Optionale Aktionen je Ordnerzeile (Umbenennen, Löschen …). Der abgeleitete Baum
    // lässt sie weg – dort gibt es nichts zu bearbeiten.
    [Parameter] public RenderFragment<NoteTreeBuilder.Node>? NodeActions { get; set; }

    private void Toggle(string key)
    {
        if (!Collapsed.Remove(key)) Collapsed.Add(key);
    }

    private static string Icon(NoteTreeBuilder.NodeKind kind) => kind switch
    {
        NoteTreeBuilder.NodeKind.Workspace => "🗂",
        NoteTreeBuilder.NodeKind.Project   => "📁",
        NoteTreeBuilder.NodeKind.Task      => "🗒",
        NoteTreeBuilder.NodeKind.Folder    => "📁",
        _                                  => "📂"
    };
}
