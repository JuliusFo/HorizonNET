@* Wiederverwendbarer Filter-Umschalter (Trichter). Gefüllt = Filter aktiv.
   Genutzt in der Projekt-Übersicht (Arbeitsbereiche) und im Arbeitsbereich (Projekte).
   stopPropagation, damit der Button in klickbaren Containern nichts anderes auslöst. *@
<button type="button"
        class="btn btn-sm btn-icon @(Active ? "btn-primary" : "btn-outline-secondary") @Class"
        @onclick="OnClick"
        @onclick:stopPropagation="true"
        title="@(Active ? ActiveTitle : Title)">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
        @if (Active)
        {
            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5z" />
        }
        else
        {
            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zM2 2v1.293l4.372 4.858A.5.5 0 0 1 6.5 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.349L13 3.293V2z" />
        }
    </svg>
</button>

@code {
    /// Ist der Filter für dieses Element gerade aktiv?
    [Parameter] public bool Active { get; set; }

    [Parameter] public EventCallback OnClick { get; set; }

    /// Tooltip im inaktiven Zustand.
    [Parameter] public string Title { get; set; } = "Filtern";

    /// Tooltip im aktiven Zustand.
    [Parameter] public string ActiveTitle { get; set; } = "Filter entfernen";

    /// Zusätzliche CSS-Klassen.
    [Parameter] public string? Class { get; set; }
}
