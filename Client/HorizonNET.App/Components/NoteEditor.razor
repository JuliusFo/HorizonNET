@inject ApiService Api
@implements IAsyncDisposable

@* Editor für eine einzelne Notiz mit debounced Auto-Save (2 s nach letzter Änderung).
   Ausstehende Änderungen werden beim Wechsel auf eine andere Notiz und beim Verlassen
   der Seite noch gespeichert (FlushAsync / DisposeAsync). *@
@if (loaded is null)
{
    <div class="note-empty text-muted">Keine Notiz ausgewählt.</div>
}
else
{
    <div class="note-editor">
        <div class="note-editor-bar">
            <input class="form-control form-control-lg fw-semibold note-editor-title"
                   placeholder="Titel…" value="@title" @oninput="OnTitleInput" />
            <span class="note-editor-status">@StatusText</span>
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="DeleteAsync"
                    title="Notiz löschen">🗑</button>
        </div>

        <div class="note-editor-meta">
            <ProjectSelect @bind-Value="selectedProjectId" Change="OnProjectChanged" />

            <RadzenDropDown TValue="int?" Data="taskOptions" TextProperty="Label" ValueProperty="Id"
                            @bind-Value="selectedTaskId" Change="OnAssignmentChanged"
                            AllowFiltering="true" AllowClear="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="— kein Task —" class="note-assign-task" />

            <span class="text-muted ms-auto">Geändert: @loaded.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</span>
        </div>

        @* Value wird EINWEG gebunden und nur beim Notiz-Wechsel gesetzt. Würde man
           @bind-Value nutzen, schriebe Radzen den Inhalt bei jedem Tastendruck zurück
           in den DOM → spürbare Eingabeverzögerung. Änderungen holen wir über Input/Change. *@
        <RadzenHtmlEditor Value="@editorValue" Input="OnContentInput" Change="OnContentInput"
                          class="note-editor-html" />
    </div>
}

@code {
    // Aktuell zu bearbeitende Notiz; null = nichts ausgewählt.
    [Parameter] public NoteResponseDto? Note { get; set; }

    // Nach erfolgreichem Speichern (für Listenaktualisierung beim Aufrufer).
    [Parameter] public EventCallback<NoteResponseDto> OnSaved { get; set; }

    // Nach dem Löschen.
    [Parameter] public EventCallback<int> OnDeleted { get; set; }

    private NoteResponseDto? loaded;   // Snapshot der geladenen Notiz (Save-Ziel)
    private string title = string.Empty;
    private string editorValue = string.Empty; // stabil an den Editor gebunden (nur bei Wechsel gesetzt)
    private string content = string.Empty;     // laufender Bearbeitungsstand (zum Speichern)
    private SaveState state = SaveState.Saved;
    private CancellationTokenSource? debounceCts;
    private bool skipNextRender;               // unterdrückt Re-Renders während des Tippens

    // Zuordnung (Projekt/Task) – aus der geladenen Notiz übernommen, per Dropdown änderbar.
    private int? selectedProjectId;
    private int? selectedTaskId;
    private List<TaskResponseDto> allTasks = new();
    private List<TaskOption> taskOptions = new();

    // Auswahl-Eintrag für das Task-Dropdown (Sub-Tasks mit ↳ gekennzeichnet).
    private record TaskOption(int Id, string Label);

    private static readonly StringComparer NameComparer = StringComparer.CurrentCultureIgnoreCase;

    protected override async Task OnInitializedAsync()
    {
        allTasks = await Api.GetTasksAsync() ?? new();
        RebuildTaskOptions();
    }

    // Ist ein Projekt gewählt, nur dessen Tasks anbieten – sonst alle.
    // Sortierung: Haupt-Tasks A-Z, ihre Sub-Tasks jeweils A-Z direkt darunter.
    private void RebuildTaskOptions()
    {
        var source = selectedProjectId is int projectId
            ? allTasks.Where(t => t.ProjectId == projectId)
            : allTasks;

        taskOptions = new();
        foreach (var t in source.OrderBy(t => t.Title, NameComparer))
        {
            taskOptions.Add(new TaskOption(t.Id, t.Title));
            if (t.SubTasks is not null)
                foreach (var s in t.SubTasks.OrderBy(s => s.Title, NameComparer))
                    taskOptions.Add(new TaskOption(s.Id, "↳ " + s.Title));
        }
    }

    // Während des Tippens NICHT neu rendern – sonst schreibt Radzen den Editor-DOM neu.
    // Beim Laden einer Notiz und bei Statuswechseln (Speichern) rendern wir normal.
    protected override bool ShouldRender()
    {
        if (skipNextRender) { skipNextRender = false; return false; }
        return true;
    }

    private enum SaveState { Saved, Pending, Saving, Error }

    private string StatusText => state switch
    {
        SaveState.Pending => "Nicht gespeichert…",
        SaveState.Saving  => "Speichert…",
        SaveState.Error   => "Fehler beim Speichern",
        _                 => "Gespeichert"
    };

    protected override async Task OnParametersSetAsync()
    {
        if (Note is null) { loaded = null; return; }
        if (loaded?.Id == Note.Id) return;

        // Wechsel auf eine andere Notiz: ausstehende Änderungen der alten sichern.
        await FlushAsync();

        loaded            = Note;
        title             = Note.Title;
        content           = Note.Content ?? string.Empty;
        editorValue       = content; // nur hier setzen → Editor schreibt den DOM nur beim Wechsel
        selectedProjectId = Note.ProjectId;
        selectedTaskId    = Note.TaskItemId;
        state             = SaveState.Saved;

        // Task-Auswahl auf das Projekt der geladenen Notiz einschränken.
        RebuildTaskOptions();
    }

    // ProjectSelect/Task-Dropdown aktualisieren selectedProjectId/selectedTaskId über
    // @bind-Value; hier nur den Auto-Save anstoßen (parameterlos → bindet an beide Events).
    private void OnAssignmentChanged() => ScheduleSave();

    // Projektwechsel: Task-Auswahl neu aufbauen. Gehört der bisher zugeordnete Task
    // nicht zum neuen Projekt, wird die Zuordnung verworfen (sonst bliebe eine
    // Task-Id gespeichert, die im Dropdown gar nicht mehr auftaucht).
    private void OnProjectChanged()
    {
        RebuildTaskOptions();

        if (selectedTaskId is int taskId && taskOptions.All(o => o.Id != taskId))
            selectedTaskId = null;

        ScheduleSave();
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        title = e.Value?.ToString() ?? string.Empty;
        skipNextRender = true;
        ScheduleSave();
    }

    // Neuer HTML-Inhalt aus dem Editor (Input = beim Tippen, Change = bei Blur/Befehl).
    // editorValue bleibt bewusst unverändert, damit Radzen den DOM nicht neu schreibt.
    private void OnContentInput(string html)
    {
        content = html;
        skipNextRender = true;
        ScheduleSave();
    }

    private void ScheduleSave()
    {
        state = SaveState.Pending;
        debounceCts?.Cancel();
        debounceCts = new CancellationTokenSource();
        _ = DebouncedSaveAsync(debounceCts.Token);
    }

    private async Task DebouncedSaveAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(2000, token);
            await SaveAsync();
        }
        catch (TaskCanceledException) { /* durch neue Eingabe ersetzt */ }
    }

    // Speichert ausstehende Änderungen sofort (z. B. vor Notiz-Wechsel / Verlassen).
    public async Task FlushAsync()
    {
        if (loaded is not null && state is SaveState.Pending or SaveState.Error)
            await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (loaded is null) return;

        debounceCts?.Cancel();
        state = SaveState.Saving;
        await InvokeAsync(StateHasChanged);

        var dto = new NoteUpdateDto(title.Trim(), content, selectedTaskId, selectedProjectId);
        var updated = await Api.UpdateNoteAsync(loaded.Id, dto);

        if (updated is null)
        {
            state = SaveState.Error;
            await InvokeAsync(StateHasChanged);
            return;
        }

        loaded = updated;
        state  = SaveState.Saved;
        await OnSaved.InvokeAsync(updated);
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteAsync()
    {
        if (loaded is null) return;

        debounceCts?.Cancel();
        var id = loaded.Id;
        var ok = await Api.DeleteNoteAsync(id);
        if (!ok) return;

        loaded = null;
        await OnDeleted.InvokeAsync(id);
    }

    public async ValueTask DisposeAsync()
    {
        debounceCts?.Cancel();
        await FlushAsync();
        debounceCts?.Dispose();
    }
}
