@inject ApiService Api
@inject IStringLocalizer<Enums> EnumL
@inject SoundService Sound
@inject ToastService Toast

@* Wiederverwendbarer Bearbeiten-Dialog für Tasks (leichtgewichtiges Overlay,
   kein JS-Interop). Die Sichtbarkeit steuert der Aufrufer über den Task-Parameter. *@
@if (Task is not null)
{
    <div class="task-dialog-backdrop" @onclick="CloseAsync"></div>
    <div class="task-dialog">
        <div class="task-dialog-content" @onclick:stopPropagation="true">
            <div class="task-dialog-header">
                <h5 class="mb-0">Task bearbeiten</h5>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-sm btn-outline-secondary" href="@($"tasks/{Task.Id}")"
                       title="Zur Detailseite">Details</a>
                    <button type="button" class="btn-close" @onclick="CloseAsync" aria-label="Schließen"></button>
                </div>
            </div>

            <div class="task-dialog-body">
                @* Hauptfelder – eigenes Formular, damit das Sub-Task-Eingabefeld
                   unten (außerhalb des Formulars) bei Enter nichts absendet. *@
                <EditForm id="taskEditForm" Model="editModel" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Titel</label>
                        <InputText class="form-control" @bind-Value="editModel.Title" />
                        <ValidationMessage For="() => editModel.Title" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Beschreibung</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="editModel.Description" />
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Fällig</label>
                            <InputDate class="form-control" @bind-Value="editModel.DueDate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Von</label>
                            <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="editModel.StartTime"
                                       disabled="@(editModel.DueDate is null)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bis</label>
                            <InputDate Type="InputDateType.Time" class="form-control" @bind-Value="editModel.EndTime"
                                       disabled="@(editModel.DueDate is null)" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <InputSelect class="form-select" @bind-Value="editModel.Status">
                                @foreach (var s in Enum.GetValues<WorkStatus>())
                                {
                                    <option value="@s">@EnumL[$"WorkStatus_{s}"]</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Priorität</label>
                            <InputSelect class="form-select" @bind-Value="editModel.Priority">
                                @foreach (var p in Enum.GetValues<Priority>())
                                {
                                    <option value="@p">@PriorityDisplay.Symbol(p) @EnumL[$"Priority_{p}"]</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    @if (editError is not null)
                    {
                        <div class="alert alert-danger py-1 mt-3 mb-0">@editError</div>
                    }
                </EditForm>

                @* Sub-Tasks – nur bei Haupt-Tasks (eine Verschachtelungsebene) *@
                @if (Task.ParentTaskId is null)
                {
                    <hr class="my-3" />
                    <SubTaskList ParentTaskId="Task.Id" ProjectId="Task.ProjectId"
                                 SubTasks="subTasks" SubTasksChanged="HandleSubTasksChanged" />
                }
            </div>

            <div class="task-dialog-footer">
                <button type="button" class="btn btn-outline-danger" @onclick="DeleteAsync" disabled="@isSaving">Löschen</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary" @onclick="SaveAsTemplateAsync"
                            disabled="@isSaving" title="Titel, Beschreibung, Priorität und Projekt als Vorlage sichern">
                        Als Vorlage speichern
                    </button>
                    <button type="submit" form="taskEditForm" class="btn btn-primary" disabled="@isSaving">
                        @(isSaving ? "Speichert…" : "Speichern")
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Abbrechen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Der zu bearbeitende Task; null = Dialog geschlossen. Der Aufrufer steuert
    // die Sichtbarkeit, indem er diesen Parameter setzt bzw. wieder auf null setzt.
    [Parameter] public TaskResponseDto? Task { get; set; }

    // Liefert den aktualisierten Task nach "Speichern" (schließt den Dialog).
    [Parameter] public EventCallback<TaskResponseDto> OnSaved { get; set; }

    // Liefert die Id des gelöschten Tasks (schließt den Dialog).
    [Parameter] public EventCallback<int> OnDeleted { get; set; }

    // Live-Aktualisierung (z. B. Sub-Tasks geändert) – Dialog bleibt offen.
    [Parameter] public EventCallback<TaskResponseDto> OnTaskUpdated { get; set; }

    // Schließen ohne Speichern (X / Backdrop / Abbrechen).
    [Parameter] public EventCallback OnClose { get; set; }

    private TaskEditModel editModel = new();
    private List<TaskResponseDto> subTasks = new();
    private bool isSaving;
    private string? editError;
    private int? loadedTaskId;

    protected override void OnParametersSet()
    {
        // Nur (neu) befüllen, wenn ein anderer Task übergeben wurde.
        if (Task is null) { loadedTaskId = null; return; }
        if (loadedTaskId == Task.Id) return;

        loadedTaskId = Task.Id;
        editError    = null;
        subTasks     = Task.SubTasks?.OrderBy(s => s.SortOrder).ToList() ?? new();
        editModel = new TaskEditModel
        {
            Title       = Task.Title,
            Description = Task.Description,
            DueDate     = Task.DueDate,
            StartTime   = Task.StartTime,
            EndTime     = Task.EndTime,
            Priority    = Enum.Parse<Priority>(Task.Priority),
            Status      = Task.Status
        };
    }

    // ── Hauptfelder ────────────────────────────────────────────────────────────

    private async Task SaveAsync()
    {
        if (Task is null) return;

        isSaving  = true;
        editError = null;

        var dto = new TaskUpdateDto(
            editModel.Title,
            string.IsNullOrWhiteSpace(editModel.Description) ? null : editModel.Description,
            editModel.DueDate, editModel.StartTime, editModel.EndTime,
            editModel.Status, editModel.Priority, Task.ProjectId);

        var wasDone = Task.Status == WorkStatus.Done;

        var updated = await Api.UpdateTaskAsync(Task.Id, dto);
        isSaving = false;

        if (updated is null)
        {
            editError = "Speichern fehlgeschlagen.";
            await Sound.ErrorAsync();
            return;
        }

        // Frisch auf "erledigt" gesetzt → Erfolgs-Ton.
        if (editModel.Status == WorkStatus.Done && !wasDone)
            await Sound.SuccessAsync();

        // Die API liefert beim Update keine Sub-Tasks mit – lokalen Stand erhalten.
        updated = updated with { SubTasks = subTasks.Count > 0 ? subTasks.ToList() : null };
        await OnSaved.InvokeAsync(updated);
    }

    // Sichert den aktuellen Formularstand als Vorlage (ohne Termine/Status – die
    // sind pro Task individuell). Der Dialog bleibt offen, ungespeicherte
    // Task-Änderungen bleiben davon unberührt.
    private async Task SaveAsTemplateAsync()
    {
        if (Task is null || string.IsNullOrWhiteSpace(editModel.Title)) return;

        isSaving = true;

        var created = await Api.CreateTaskTemplateAsync(new TaskTemplateCreateDto(
            editModel.Title,
            string.IsNullOrWhiteSpace(editModel.Description) ? null : editModel.Description,
            editModel.Priority,
            Task.ProjectId));

        isSaving = false;

        if (created is null)
        {
            editError = "Vorlage konnte nicht gespeichert werden.";
            await Sound.ErrorAsync();
            return;
        }

        Toast.ShowSuccess($"Vorlage „{created.Title}\" gespeichert");
    }

    private async Task DeleteAsync()
    {
        if (Task is null) return;

        var id = Task.Id;
        var ok = await Api.DeleteTaskAsync(id);
        if (!ok)
        {
            editError = "Löschen fehlgeschlagen.";
            await Sound.ErrorAsync();
            return;
        }

        await OnDeleted.InvokeAsync(id);
    }

    private async Task CloseAsync() => await OnClose.InvokeAsync();

    // ── Sub-Tasks ────────────────────────────────────────────────────────────────

    // Die SubTaskList wirkt sofort über die API und meldet den neuen Stand hier zurück.
    private async Task HandleSubTasksChanged(List<TaskResponseDto> updated)
    {
        subTasks = updated;
        await NotifyTaskUpdatedAsync();
    }

    private async Task NotifyTaskUpdatedAsync()
    {
        if (Task is null) return;
        await OnTaskUpdated.InvokeAsync(Task with { SubTasks = subTasks.Count > 0 ? subTasks.ToList() : null });
    }

    private class TaskEditModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Titel ist erforderlich.")]
        [System.ComponentModel.DataAnnotations.MaxLength(300)]
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }

        private DateTime? dueDate;
        public DateTime? DueDate
        {
            get => dueDate;
            set
            {
                dueDate = value;
                // Ohne Fälligkeitsdatum ergibt eine Uhrzeit keinen Sinn → mitlöschen.
                if (value is null) { StartTime = null; EndTime = null; }
            }
        }

        public DateTime? StartTime { get; set; }
        public DateTime? EndTime { get; set; }
        public Priority Priority { get; set; } = Priority.Medium;
        public WorkStatus Status { get; set; } = WorkStatus.Planned;
    }
}
