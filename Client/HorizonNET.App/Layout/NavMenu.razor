<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HorizonNET</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="today">
                <span class="bi bi-calendar-check-nav-menu" aria-hidden="true"></span> Heute
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Übersicht
            </NavLink>
        </div>

        @* Aktive Projekte ohne Arbeitsbereich – direkt unter "Übersicht" *@
        @if (UngroupedActiveProjects.Any())
        {
            <div class="nav-item px-3 nav-subitems">
                @foreach (var project in UngroupedActiveProjects)
                {
                    <NavLink class="nav-link nav-sublink" href="@($"projects/{project.Id}")">
                        <span class="nav-project-dot" style="@DotStyle(project.Color)" aria-hidden="true"></span>
                        @project.Name
                    </NavLink>
                }
            </div>
        }

        @* Arbeitsbereiche mit ihren aktiven Projekten *@
        @foreach (var workspace in WorkspacesWithActiveProjects)
        {
            <div class="nav-item nav-workspace">
                <NavLink class="nav-workspace-link" href="@($"workspaces/{workspace.Id}")">
                    <span class="nav-workspace-dot" style="@DotStyle(workspace.Color)" aria-hidden="true"></span>
                    @workspace.Name
                </NavLink>
            </div>
            <div class="nav-item px-3 nav-subitems">
                @foreach (var project in ActiveProjectsIn(workspace.Id))
                {
                    <NavLink class="nav-link nav-sublink" href="@($"projects/{project.Id}")">
                        <span class="nav-project-dot" style="@DotStyle(project.Color)" aria-hidden="true"></span>
                        @project.Name
                    </NavLink>
                }
            </div>
        }

        @* Die laufende Zeiterfassung steht in der Kopfzeile (RunningTimerIndicator). *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="calendar">
                <span class="bi bi-calendar3-nav-menu" aria-hidden="true"></span> Kalender
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="notes">
                <span class="bi bi-journal-text-nav-menu" aria-hidden="true"></span> Notizen
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sport">
                <span class="bi bi-dumbbell-nav-menu" aria-hidden="true"></span> Sport
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="papierkorb">
                <span class="bi bi-trash-nav-menu" aria-hidden="true"></span> Papierkorb
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="bi bi-gear-nav-menu" aria-hidden="true"></span> Einstellungen
            </NavLink>
        </div>
    </nav>
</div>

@inject ProjectState ProjectState
@inject WorkspaceState WorkspaceState
@implements IDisposable

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private IEnumerable<ProjectResponseDto> ActiveProjects =>
        ProjectState.Projects?.Where(p => p.Status == "Active") ?? [];

    private HashSet<int> ExistingWorkspaceIds =>
        (WorkspaceState.Workspaces ?? []).Select(w => w.Id).ToHashSet();

    // Ohne Arbeitsbereich ODER dessen Arbeitsbereich existiert nicht (mehr) –
    // z. B. nach Soft-Delete des Arbeitsbereichs behalten Projekte ihre WorkspaceId.
    private IEnumerable<ProjectResponseDto> UngroupedActiveProjects =>
        ActiveProjects.Where(p => p.WorkspaceId is null || !ExistingWorkspaceIds.Contains(p.WorkspaceId.Value));

    private IEnumerable<ProjectResponseDto> ActiveProjectsIn(int workspaceId) =>
        ActiveProjects.Where(p => p.WorkspaceId == workspaceId);

    // Nur Arbeitsbereiche zeigen, die auch aktive Projekte enthalten
    private IEnumerable<WorkspaceResponseDto> WorkspacesWithActiveProjects =>
        (WorkspaceState.Workspaces ?? [])
            .Where(w => ActiveProjects.Any(p => p.WorkspaceId == w.Id));

    private static string DotStyle(string? color) =>
        color is not null ? $"background-color: {color};" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ProjectState.OnChange += HandleChanged;
        WorkspaceState.OnChange += HandleChanged;

        await ProjectState.EnsureLoadedAsync();
        await WorkspaceState.EnsureLoadedAsync();
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    public void Dispose()
    {
        ProjectState.OnChange -= HandleChanged;
        WorkspaceState.OnChange -= HandleChanged;
    }
}
