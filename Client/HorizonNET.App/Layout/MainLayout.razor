@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="btn btn-sm btn-outline-secondary me-auto search-btn" @onclick="OpenSearchAsync"
                    title="Globale Suche (Strg+K)">
                🔍 Suchen <kbd>Strg</kbd><span class="kbd-plus">+</span><kbd>K</kbd>
            </button>
            <RunningTimerIndicator />
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<ToastHost />
<ConfirmDialogHost />
<SearchPalette @ref="searchPalette" />

@* Host für die Radzen-Dialoge. Ohne ihn bleiben die Toolbar-Buttons des RadzenHtmlEditor,
   die einen Dialog öffnen (Link, Bild, Farbe), folgenlos. *@
<RadzenComponents />

@inject VersionState Version

@code {
    private SearchPalette? searchPalette;

    // Beim App-Start die API-Version prüfen und bei Versatz zum Neuladen auffordern.
    // Bewusst nicht awaiten, damit die GET-Anfrage das Layout-Rendern nicht blockiert.
    protected override void OnInitialized() => _ = Version.CheckForMismatchAsync();

    private async Task OpenSearchAsync()
    {
        if (searchPalette is not null)
            await searchPalette.OpenAsync();
    }
}
